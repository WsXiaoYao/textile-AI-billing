<view class="customer-list-card" bindtap="onOpen">
  <view class="customer-main">
    <view class="customer-info">
      <view class="customer-title-row">
        <view class="customer-name">{{customer.name}}</view>
        <view class="customer-tag">{{customer.tag}}</view>
      </view>
      <view class="customer-meta">{{customer.code}} · {{customer.phone}}</view>
      <view class="customer-address-line">
        <text class="customer-area" wx:if="{{customer.area}}">地区 {{customer.area}}</text>
        <text class="customer-address">{{customer.address}}</text>
      </view>
    </view>

    <view class="customer-balance">
      <view class="status-pill status-{{customer.statusTone}}">{{customer.statusText}}</view>
      <view class="balance-label">{{customer.balanceLabel}}</view>
      <view class="balance-value balance-{{customer.balanceTone}}">{{customer.balanceText}}</view>
    </view>
  </view>

</view>
