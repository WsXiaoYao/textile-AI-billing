:host {
  display: block;
  width: 100%;
}

.order-summary-card {
  width: 100%;
  min-height: 192rpx;
  padding: 26rpx 30rpx 22rpx;
  border: 1rpx solid #d8e5f6;
  border-radius: 24rpx;
  background: #ffffff;
}

.summary-title {
  color: #1d2129;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.4;
}

.summary-metrics {
  margin-top: 8rpx;
  display: flex;
  align-items: flex-start;
}

.summary-metric {
  min-width: 0;
  flex: 1;
  text-align: center;
}

.metric-label {
  color: #667085;
  font-size: 22rpx;
  line-height: 32rpx;
}

.metric-value {
  margin-top: 4rpx;
  color: #1d2129;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 44rpx;
}

.metric-danger {
  color: #d94a55;
}

.metric-success {
  color: #0e8a62;
}

.metric-primary {
  color: #2e7bef;
}

.metric-info {
  color: #0794b8;
}

.metric-warning {
  color: #f79009;
}
