:host {
  display: block;
  width: 100%;
}

.customer-switcher {
  margin-top: 28rpx;
  display: flex;
  gap: 12rpx;
  width: 100%;
}

.customer-chip {
  min-width: 0;
  height: 68rpx;
  padding: 0 20rpx;
  flex: 1;
  border: 2rpx solid #cfe0f7;
  border-radius: 16rpx;
  background: #ffffff;
  color: #2f7df6;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 64rpx;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.customer-chip.is-wide {
  flex: 1.38;
}

.customer-chip.is-more {
  flex: 0.64;
}

.customer-chip.is-active {
  border-color: #2f7df6;
  background: #2f7df6;
  color: #ffffff;
}

.chip-hover {
  opacity: 0.78;
}
