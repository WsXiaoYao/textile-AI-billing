:host {
  display: block;
  width: 100%;
}

.customer-summary-card {
  width: 100%;
  min-height: 192rpx;
  padding: 24rpx 28rpx;
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  border: 1rpx solid rgba(230, 236, 245, 0.82);
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 20rpx rgba(20, 33, 56, 0.09);
}

.customer-main {
  min-width: 0;
  flex: 1;
}

.customer-label {
  color: #2f7df6;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 30rpx;
}

.customer-name-line {
  margin-top: 14rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-width: 0;
}

.customer-name {
  max-width: 276rpx;
  color: #1f2937;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 44rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.customer-tag {
  min-width: 128rpx;
  height: 46rpx;
  padding: 0 18rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  background: #eaf2ff;
  color: #2f80ed;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 46rpx;
  white-space: nowrap;
}

.customer-code {
  margin-top: 12rpx;
  color: #667085;
  font-size: 24rpx;
  line-height: 36rpx;
}

.customer-amount {
  width: 214rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.amount-label {
  color: #6b7280;
  font-size: 22rpx;
  line-height: 32rpx;
}

.amount-value {
  margin-top: 4rpx;
  color: #d94a55;
  font-size: 38rpx;
  font-weight: 800;
  line-height: 48rpx;
  white-space: nowrap;
}

.receivable-link {
  min-height: 36rpx;
  margin-top: 8rpx;
  color: #2e7bef;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 36rpx;
  text-align: right;
  white-space: nowrap;
}

.link-hover {
  opacity: 0.7;
}
