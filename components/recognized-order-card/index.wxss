:host {
  display: block;
  width: 100%;
}

.recognized-card {
  width: 100%;
  min-height: 356rpx;
  padding: 22rpx 26rpx 20rpx;
  display: block;
  border: 1rpx solid #e6ecf5;
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 6rpx 10rpx rgba(13, 31, 61, 0.05);
  text-align: left;
  box-sizing: border-box;
}

.recognized-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.recognized-title {
  min-width: 0;
  flex: 1 1 auto;
  color: #1d2129;
  font-size: 30rpx;
  line-height: 44rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.recognized-link {
  flex: 0 0 auto;
  color: #0e8a62;
  font-size: 21rpx;
  line-height: 36rpx;
  white-space: nowrap;
}

.recognized-table-head,
.recognized-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.recognized-table-head {
  margin-top: 12rpx;
  color: #98a2b3;
  font-size: 22rpx;
  line-height: 36rpx;
}

.recognized-row {
  min-height: 62rpx;
  border-bottom: 1rpx solid #e6ecf5;
  color: #1d2129;
  font-size: 26rpx;
  line-height: 36rpx;
}

.recognized-row.is-last {
  border-bottom: 0;
}

.col-name,
.col-spec,
.col-qty,
.col-amount {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.col-name {
  flex: 1 1 0;
}

.col-spec {
  flex: 0 0 160rpx;
}

.col-qty {
  flex: 0 0 72rpx;
  text-align: center;
}

.col-amount {
  flex: 0 0 104rpx;
  text-align: right;
}

.goods-spec {
  color: #667085;
  font-size: 24rpx;
}

.goods-amount,
.recognized-total {
  color: #d94a55;
}

.recognized-total {
  margin-top: 8rpx;
  font-size: 28rpx;
  line-height: 40rpx;
  text-align: right;
}

.card-hover {
  background: #f8fafc;
}
