<view class="order-filter-bar">
  <view class="search-row">
    <input
      class="search-input"
      value="{{keyword}}"
      placeholder="{{searchPlaceholder}}"
      placeholder-class="search-placeholder"
      confirm-type="search"
      bindinput="onKeywordInput"
      bindconfirm="onKeywordConfirm"
    />
  </view>

  <view class="category-tabs" wx:if="{{statusTabs.length}}">
    <block wx:for="{{statusTabs}}" wx:key="value">
      <view
        class="category-tab {{item.value == activeStatus ? 'category-tab-active' : ''}}"
        data-value="{{item.value}}"
        bindtap="onStatusTap"
      >
        {{item.label}}
      </view>
    </block>
  </view>

  <view class="query-row">
    <view class="date-trigger" wx:if="{{dateVisible}}" bindtap="onDateTap">
      <view class="date-label">{{dateTitle}}</view>
      <view class="date-value">{{dateLabel}}</view>
    </view>
    <view class="date-arrow" wx:if="{{dateVisible}}">⌄</view>
    <view class="query-divider" wx:if="{{dateVisible}}"></view>
    <picker
      class="query-picker"
      mode="selector"
      range="{{sortOptions}}"
      range-key="label"
      value="{{sortIndex}}"
      bindchange="onSortPickerChange"
    >
      <view class="query-action">{{sortLabel}}⌄</view>
    </picker>
    <view class="query-divider" wx:if="{{filterVisible}}"></view>
    <view class="query-action" wx:if="{{filterVisible}}" bindtap="onFilterTap">
      {{filterLabel}}<text wx:if="{{filterCount}}">·{{filterCount}}</text>⌄
    </view>
  </view>
</view>
