generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EmployeeStatus {
  enabled
  disabled
}

enum ProductStatus {
  enabled
  disabled
}

enum WarehouseStatus {
  enabled
  disabled
}

enum PaymentState {
  unpaid
  partial
  paid
  overpaid
  prepaid
  refunded
}

enum ShippingState {
  unshipped
  partial
  delivered
  overdelivered
  refused
}

enum PrintState {
  unprinted
  printed
}

enum PurchaseOrderState {
  draft
  submitted
}

enum ReturnOrderState {
  pending
  partial
  prepay
  refunded
}

enum FundRecordType {
  sales_receipt
  customer_receipt
  prepayment
  prepayment_offset
  refund
  adjustment
}

enum InventoryLedgerType {
  sales_out
  purchase_in
  return_in
  adjustment
}

enum ImportTaskType {
  customer_import
  customer_export
  product_import
  product_export
  category_import
}

enum TaskStatus {
  pending
  parsing
  success
  failed
}

enum MessageStatus {
  unread
  read
}

enum MessageType {
  inventory_warning
  print_result
  organization_notice
  system
}

model Organization {
  id        String   @id @default(cuid())
  tenantId  String?  @map("tenant_id")
  name      String
  code      String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant             Tenant?             @relation(fields: [tenantId], references: [id])
  userOrgRels        UserOrgRel[]
  employeeWarehouses EmployeeWarehouse[]
  roles              Role[]
  employees          Employee[]
  authSessions       AuthSession[]
  warehouses         Warehouse[]
  customers          Customer[]
  customerCategories CustomerCategory[]
  accounts           Account[]
  categories         ProductCategory[]
  suppliers          Supplier[]
  messages           Message[]
  importTasks        ImportExportTask[]
  auditLogs          AuditLog[]
  receiptOrders      ReceiptOrder[]
  receiptOrderItems  ReceiptOrderItem[]
  orgSetting         OrgSetting?

  @@index([tenantId])
}

model User {
  id               String    @id @default(cuid())
  tenantId         String?   @map("tenant_id")
  openid           String?   @unique
  unionid          String?
  name             String
  phone            String?   @unique
  phoneCountryCode String?
  phoneVerifiedAt  DateTime?
  avatarUrl        String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  tenant       Tenant?       @relation(fields: [tenantId], references: [id])
  userOrgRels  UserOrgRel[]
  employees    Employee[]
  authSessions AuthSession[]

  @@index([tenantId])
}

model AuthSession {
  id         String   @id @default(cuid())
  tenantId   String?  @map("tenant_id")
  userId     String
  orgId      String?
  employeeId String?
  tokenHash  String   @unique
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant       Tenant?       @relation(fields: [tenantId], references: [id])
  user         User          @relation(fields: [userId], references: [id])
  organization Organization? @relation(fields: [orgId], references: [id])
  employee     Employee?     @relation(fields: [employeeId], references: [id])

  @@index([tenantId])
  @@index([userId, expiresAt])
  @@index([orgId])
}

model Role {
  id          String   @id @default(cuid())
  tenantId    String?  @map("tenant_id")
  orgId       String
  name        String
  description String?
  permissions Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant       Tenant?      @relation(fields: [tenantId], references: [id])
  organization Organization @relation(fields: [orgId], references: [id])
  employees    Employee[]
  employeeRoles EmployeeRole[]

  @@index([tenantId])
  @@unique([orgId, name])
  @@index([orgId])
}

model Employee {
  id           String         @id @default(cuid())
  tenantId     String?        @map("tenant_id")
  orgId        String
  userId       String?
  roleId       String?
  name         String
  phone        String?
  status       EmployeeStatus @default(enabled)
  warehouseIds String[]       @default([])
  remark       String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  tenant             Tenant?             @relation(fields: [tenantId], references: [id])
  organization       Organization        @relation(fields: [orgId], references: [id])
  user               User?               @relation(fields: [userId], references: [id])
  role               Role?               @relation(fields: [roleId], references: [id])
  employeeRoles      EmployeeRole[]
  authSessions       AuthSession[]
  userOrgRels        UserOrgRel[]
  employeeWarehouses EmployeeWarehouse[]

  @@index([tenantId])
  @@index([orgId, phone])
  @@index([orgId, roleId])
}

model EmployeeRole {
  id         String   @id @default(cuid())
  tenantId   String?  @map("tenant_id")
  orgId      String
  employeeId String
  roleId     String
  isPrimary  Boolean  @default(false) @map("is_primary")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  role     Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([employeeId, roleId])
  @@index([tenantId])
  @@index([orgId])
  @@index([roleId])
  @@map("employee_roles")
}

model Warehouse {
  id        String          @id @default(cuid())
  tenantId  String?         @map("tenant_id")
  orgId     String
  name      String
  manager   String?
  address   String?
  isDefault Boolean         @default(false)
  status    WarehouseStatus @default(enabled)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  employeeWarehouses EmployeeWarehouse[]
  organization      Organization       @relation(fields: [orgId], references: [id])
  inventoryBalances InventoryBalance[]
  inventoryLedgers  InventoryLedger[]
  salesOrders       SalesOrder[]
  purchaseOrders    PurchaseOrder[]
  returnOrders      ReturnOrder[]

  @@index([tenantId])
  @@unique([orgId, name])
  @@index([orgId, status])
}

model Tenant {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  status    String   @default("enabled")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizations      Organization[]
  users              User[]
  authSessions       AuthSession[]
  roles              Role[]
  employees          Employee[]
  userOrgRels        UserOrgRel[]
  employeeWarehouses EmployeeWarehouse[]
  orgSettings        OrgSetting[]
}

model OrgSetting {
  id                String   @id @default(cuid())
  tenantId          String?  @map("tenant_id")
  orgId             String   @unique @map("org_id")
  paymentQrcodeUrl  String?  @map("payment_qrcode_url") @db.VarChar(500)
  qrcodeRemark      String?  @map("qrcode_remark") @db.VarChar(500)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  tenant       Tenant?      @relation(fields: [tenantId], references: [id])
  organization Organization @relation(fields: [orgId], references: [id])

  @@index([tenantId])
  @@map("org_settings")
}

model UserOrgRel {
  id         String   @id @default(cuid())
  tenantId   String?  @map("tenant_id")
  userId     String
  orgId      String
  employeeId String?
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant       Tenant?       @relation(fields: [tenantId], references: [id])
  user         User          @relation(fields: [userId], references: [id])
  organization Organization  @relation(fields: [orgId], references: [id])
  employee     Employee?     @relation(fields: [employeeId], references: [id])

  @@unique([userId, orgId])
  @@index([tenantId])
  @@index([orgId])
  @@index([employeeId])
}

model EmployeeWarehouse {
  id          String   @id @default(cuid())
  tenantId    String?  @map("tenant_id")
  orgId       String
  employeeId  String
  warehouseId String
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant       Tenant?       @relation(fields: [tenantId], references: [id])
  organization Organization  @relation(fields: [orgId], references: [id])
  employee     Employee      @relation(fields: [employeeId], references: [id])
  warehouse    Warehouse     @relation(fields: [warehouseId], references: [id])

  @@unique([employeeId, warehouseId])
  @@index([tenantId])
  @@index([orgId, warehouseId])
}

model Customer {
  id                       BigInt   @id @default(autoincrement())
  tenantId                 String?  @map("tenant_id")
  org_id                   String
  customer_category_id     String?
  customer_name            String   @db.VarChar(255)
  customer_category        String   @default("未分类") @db.VarChar(50)
  phone                    String?  @db.VarChar(30)
  backup_phone             String?  @db.VarChar(30)
  fax                      String?  @db.VarChar(50)
  remark                   String?
  address_short            String?  @db.VarChar(255)
  province                 String?  @db.VarChar(50)
  city                     String?  @db.VarChar(100)
  district                 String?  @db.VarChar(100)
  detail_address           String?
  address_remark           String?
  zipcode                  String?  @db.VarChar(20)
  opening_debt             Decimal  @default(0) @db.Decimal(18, 2)
  contract_amount          Decimal  @default(0) @db.Decimal(18, 2)
  delivered_amount         Decimal  @default(0) @db.Decimal(18, 2)
  prepaid_amount           Decimal  @default(0) @db.Decimal(18, 2)
  unpaid_amount            Decimal  @default(0) @db.Decimal(18, 2)
  paid_amount              Decimal  @default(0) @db.Decimal(18, 2)
  is_active                Boolean  @default(true)
  source_file              String   @default("") @db.VarChar(255)
  source_sheet             String   @default("") @db.VarChar(100)
  source_row_no            Int      @default(0)
  customer_name_normalized String   @default("") @db.VarChar(255)
  customer_name_pinyin     String   @default("") @db.VarChar(255)
  customer_name_initials   String   @default("") @db.VarChar(255)
  created_at               DateTime @default(now()) @db.Timestamptz(6)
  updated_at               DateTime @updatedAt @db.Timestamptz(6)

  organization     Organization      @relation(fields: [org_id], references: [id])
  customerCategory CustomerCategory? @relation(fields: [customer_category_id], references: [id])
  salesOrders      SalesOrder[]
  returnOrders     ReturnOrder[]
  fundRecords      FundRecord[]
  receiptOrders    ReceiptOrder[]

  @@index([tenantId])
  @@index([org_id, customer_category_id])
  @@index([org_id, customer_category])
  @@index([org_id, customer_name])
  @@index([org_id, customer_name_normalized])
  @@index([org_id, customer_name_pinyin])
  @@index([org_id, customer_name_initials])
  @@index([org_id, phone])
  @@index([org_id, province, city, district])
  @@index([org_id, is_active])
  @@map("customers")
}

model CustomerCategory {
  id         String   @id @default(cuid())
  tenantId   String?  @map("tenant_id")
  org_id     String
  name       String   @db.VarChar(50)
  sort_order Int      @default(0)
  is_active  Boolean  @default(true)
  is_default Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @updatedAt @db.Timestamptz(6)

  organization Organization @relation(fields: [org_id], references: [id])
  customers    Customer[]

  @@index([tenantId])
  @@unique([org_id, name])
  @@index([org_id, is_active, sort_order])
  @@map("customer_categories")
}

model Account {
  id             String   @id @default(cuid())
  tenantId       String?  @map("tenant_id")
  orgId          String   @map("org_id")
  accountName    String   @map("account_name") @db.VarChar(100)
  initBalance    Decimal  @default(0) @map("init_balance") @db.Decimal(18, 2)
  currentBalance Decimal  @default(0) @map("current_balance") @db.Decimal(18, 2)
  remark         String?  @db.VarChar(500)
  status         String   @default("enabled")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization  Organization   @relation(fields: [orgId], references: [id])
  receiptOrders ReceiptOrder[]

  @@index([tenantId])
  @@unique([orgId, accountName])
  @@index([orgId, status])
  @@map("accounts")
}

model ProductCategory {
  id        String   @id @default(cuid())
  tenantId  String?  @map("tenant_id")
  orgId     String
  parentId  String?
  name      String
  level     Int      @default(1)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization      @relation(fields: [orgId], references: [id])
  parent       ProductCategory?  @relation("CategoryChildren", fields: [parentId], references: [id])
  children     ProductCategory[] @relation("CategoryChildren")

  @@index([tenantId])
  @@unique([orgId, parentId, name])
  @@index([orgId, level])
}

model Product {
  id                    BigInt   @id @default(autoincrement())
  tenantId              String?  @map("tenant_id")
  orgId                 String?  @map("org_id")
  productCode           String   @unique(map: "products_1_product_code_key") @map("product_code") @db.VarChar(50)
  productName           String   @map("product_name") @db.VarChar(255)
  productNameNormalized String?  @map("product_name_normalized")
  productNamePinyin     String?  @map("product_name_pinyin")
  productNameInitials   String?  @map("product_name_initials")
  categoryName          String   @map("category_name") @db.VarChar(100)
  defaultUnit           String?  @map("default_unit") @db.VarChar(20)
  tag                   String?  @db.VarChar(50)
  remark                String?
  sourceFile            String   @map("source_file") @db.VarChar(255)
  sourceSheet           String   @map("source_sheet") @db.VarChar(100)
  sourceFirstRowNo      Int      @map("source_first_row_no")
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  allSkuValues          String   @default("") @map("all_sku_values")

  variants         ProductVariant[]
  salesItems       SalesOrderItem[]
  purchaseItems    PurchaseOrderItem[]
  returnItems      ReturnOrderItem[]
  inventoryLedgers InventoryLedger[]

  @@index([tenantId])
  @@index([orgId])
  @@index([categoryName], map: "products_category_name_idx")
  @@index([productName], map: "products_product_name_idx")
  @@index([productNameInitials], map: "products_product_name_initials_idx")
  @@index([productNameNormalized], map: "products_product_name_normalized_idx")
  @@index([productNamePinyin], map: "products_product_name_pinyin_idx")
  @@map("products")
}

model ProductVariant {
  id            BigInt   @id @default(autoincrement())
  tenantId      String?  @map("tenant_id")
  orgId         String?  @map("org_id")
  productId     BigInt   @map("product_id")
  warehouseName String   @map("warehouse_name") @db.VarChar(100)
  barcode       String?  @db.VarChar(100)
  skuCode       String?  @map("sku_code") @db.VarChar(50)
  skuValue      String?  @map("sku_value") @db.VarChar(255)
  unit          String?  @db.VarChar(20)
  salePrice     Decimal  @default(0) @map("sale_price") @db.Decimal(18, 2)
  openingStock  Decimal  @default(0) @map("opening_stock") @db.Decimal(18, 3)
  minStock      Decimal  @default(0) @map("min_stock") @db.Decimal(18, 3)
  sourceFile    String   @map("source_file") @db.VarChar(255)
  sourceSheet   String   @map("source_sheet") @db.VarChar(100)
  sourceRowNo   Int      @map("source_row_no")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  product           Product             @relation(fields: [productId], references: [id])
  inventoryBalances InventoryBalance[]
  inventoryLedgers  InventoryLedger[]
  salesItems        SalesOrderItem[]
  purchaseItems     PurchaseOrderItem[]
  returnItems       ReturnOrderItem[]

  @@index([tenantId])
  @@index([orgId])
  @@index([productId], map: "product_sku_product_id_idx")
  @@index([skuCode], map: "product_sku_sku_code_idx")
  @@index([warehouseName], map: "product_sku_warehouse_name_idx")
  @@map("product_sku")
}

model InventoryBalance {
  id          String   @id @default(cuid())
  tenantId    String?  @map("tenant_id")
  orgId       String
  warehouseId String
  variantId   BigInt
  stockQty    Decimal  @default(0) @db.Decimal(14, 2)
  reservedQty Decimal  @default(0) @db.Decimal(14, 2)
  updatedAt   DateTime @updatedAt

  warehouse Warehouse      @relation(fields: [warehouseId], references: [id])
  variant   ProductVariant @relation(fields: [variantId], references: [id])

  @@index([tenantId])
  @@unique([orgId, warehouseId, variantId])
  @@index([orgId, variantId])
}

model InventoryLedger {
  id          String              @id @default(cuid())
  tenantId    String?             @map("tenant_id")
  orgId       String
  warehouseId String
  productId   BigInt
  variantId   BigInt
  type        InventoryLedgerType
  refType     String?
  refId       String?
  beforeQty   Decimal             @db.Decimal(14, 2)
  changeQty   Decimal             @db.Decimal(14, 2)
  afterQty    Decimal             @db.Decimal(14, 2)
  reason      String?
  operator    String?
  createdAt   DateTime            @default(now())

  warehouse Warehouse      @relation(fields: [warehouseId], references: [id])
  product   Product        @relation(fields: [productId], references: [id])
  variant   ProductVariant @relation(fields: [variantId], references: [id])

  @@index([tenantId])
  @@index([orgId, variantId, createdAt])
  @@index([orgId, refType, refId])
}

model SalesOrder {
  id               BigInt   @id @default(autoincrement())
  tenantId         String?  @map("tenant_id")
  orgId            String   @map("org_id")
  orderNo          String   @map("order_no") @db.VarChar(50)
  customerId       BigInt   @map("customer_id")
  warehouseId      String?  @map("warehouse_id")
  warehouseName    String   @default("默认仓") @map("warehouse_name") @db.VarChar(100)
  orderDate        DateTime @map("order_date") @db.Date
  orderAmount      Decimal  @default(0) @map("order_amount") @db.Decimal(18, 2)
  discountAmount   Decimal  @default(0) @map("discount_amount") @db.Decimal(18, 2)
  contractAmount   Decimal  @default(0) @map("contract_amount") @db.Decimal(18, 2)
  receivedAmount   Decimal  @default(0) @map("received_amount") @db.Decimal(18, 2)
  unreceivedAmount Decimal  @default(0) @map("unreceived_amount") @db.Decimal(18, 2)
  payStatus        String   @default("unpaid") @map("pay_status") @db.VarChar(20)
  shippingStatus   String   @default("unshipped") @map("shipping_status") @db.VarChar(20)
  printStatus      String   @default("unprinted") @map("print_status") @db.VarChar(20)
  creatorUserId    String?  @map("creator_user_id")
  creatorName      String?  @map("creator_name") @db.VarChar(50)
  remark           String?  @db.VarChar(500)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  customer     Customer           @relation(fields: [customerId], references: [id])
  warehouse    Warehouse?         @relation(fields: [warehouseId], references: [id])
  items        SalesOrderItem[]
  fundRecords  FundRecord[]
  receiptItems ReceiptOrderItem[]
  returnOrders  ReturnOrder[]

  @@index([tenantId])
  @@unique([orgId, orderNo])
  @@index([orgId, customerId, orderDate])
  @@index([orgId, payStatus])
  @@index([orgId, printStatus])
  @@map("sales_orders")
}

model SalesOrderItem {
  id               BigInt   @id @default(autoincrement())
  tenantId         String?  @map("tenant_id")
  orgId            String   @map("org_id")
  orderId          BigInt   @map("order_id")
  productId        BigInt   @map("product_id")
  variantId        BigInt   @map("variant_id")
  productName      String   @map("product_name") @db.VarChar(255)
  colorName        String   @map("color_name") @db.VarChar(100)
  stockQtySnapshot Decimal? @map("stock_qty_snapshot") @db.Decimal(18, 2)
  qty              Decimal  @db.Decimal(18, 2)
  unitName         String   @map("unit_name") @db.VarChar(20)
  unitPrice        Decimal  @map("unit_price") @db.Decimal(18, 2)
  amount           Decimal  @db.Decimal(18, 2)
  createdAt        DateTime @default(now()) @map("created_at")

  order   SalesOrder     @relation(fields: [orderId], references: [id])
  product Product        @relation(fields: [productId], references: [id])
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@index([tenantId])
  @@index([orderId])
  @@index([productId, variantId])
  @@map("sales_order_items")
}

model FundRecord {
  id           String         @id @default(cuid())
  tenantId     String?        @map("tenant_id")
  orgId        String
  customerId   BigInt?
  orderId      BigInt?
  type         FundRecordType
  amountCents  Int            @default(0)
  balanceCents Int            @default(0)
  note         String?
  occurredAt   DateTime       @default(now())
  createdAt    DateTime       @default(now())

  customer Customer?   @relation(fields: [customerId], references: [id])
  order    SalesOrder? @relation(fields: [orderId], references: [id])

  @@index([tenantId])
  @@index([orgId, customerId, occurredAt])
  @@index([orgId, orderId])
}

model ReceiptOrder {
  id                  String   @id @default(cuid())
  tenantId            String?  @map("tenant_id")
  orgId               String   @map("org_id")
  receiptNo           String   @map("receipt_no")
  customerId          BigInt   @map("customer_id")
  receiptDate         DateTime @map("receipt_date")
  accountId           String   @map("account_id")
  accountNameSnapshot String   @map("account_name_snapshot") @db.VarChar(100)
  receiptAmount       Decimal  @map("receipt_amount") @db.Decimal(18, 2)
  prepayMode          Boolean  @default(false) @map("prepay_mode")
  creatorUserId       String?  @map("creator_user_id")
  remark              String?  @db.VarChar(500)
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  organization Organization       @relation(fields: [orgId], references: [id])
  customer     Customer           @relation(fields: [customerId], references: [id])
  account      Account            @relation(fields: [accountId], references: [id])
  items        ReceiptOrderItem[]

  @@index([tenantId])
  @@unique([orgId, receiptNo])
  @@index([orgId, customerId, receiptDate])
  @@index([orgId, accountId])
  @@map("receipt_orders")
}

model ReceiptOrderItem {
  id                     String   @id @default(cuid())
  tenantId               String?  @map("tenant_id")
  orgId                  String   @map("org_id")
  receiptId              String   @map("receipt_id")
  salesOrderId           BigInt?  @map("sales_order_id")
  contractAmount         Decimal  @map("contract_amount") @db.Decimal(18, 2)
  receivedAmountBefore   Decimal  @map("received_amount_before") @db.Decimal(18, 2)
  unreceivedAmountBefore Decimal  @map("unreceived_amount_before") @db.Decimal(18, 2)
  currentReceiveAmount   Decimal  @map("current_receive_amount") @db.Decimal(18, 2)
  createdAt              DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [orgId], references: [id])
  receipt      ReceiptOrder @relation(fields: [receiptId], references: [id])
  salesOrder   SalesOrder?  @relation(fields: [salesOrderId], references: [id])

  @@index([tenantId])
  @@index([orgId, receiptId])
  @@index([orgId, salesOrderId])
  @@map("receipt_order_items")
}

model Supplier {
  id                 String   @id @default(cuid())
  tenantId           String?  @map("tenant_id")
  orgId              String
  name               String
  phone              String?
  address            String?
  isFrequent         Boolean  @default(false)
  status             String   @default("enabled")
  totalPurchaseCents Int      @default(0)
  remark             String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  organization   Organization    @relation(fields: [orgId], references: [id])
  purchaseOrders PurchaseOrder[]

  @@index([tenantId])
  @@unique([orgId, name])
  @@index([orgId, phone])
}

model PurchaseOrder {
  id            String             @id @default(cuid())
  tenantId      String?            @map("tenant_id")
  orgId         String
  no            String
  supplierId    String
  warehouseId   String?
  orderDate     DateTime
  orderCents    Int                @default(0)
  contractCents Int                @default(0)
  state         PurchaseOrderState @default(draft)
  remark        String?
  creator       String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  supplier  Supplier            @relation(fields: [supplierId], references: [id])
  warehouse Warehouse?          @relation(fields: [warehouseId], references: [id])
  items     PurchaseOrderItem[]

  @@index([tenantId])
  @@unique([orgId, no])
  @@index([orgId, supplierId, orderDate])
}

model PurchaseOrderItem {
  id          String   @id @default(cuid())
  tenantId    String?  @map("tenant_id")
  orgId       String?  @map("org_id")
  orderId     String
  productId   BigInt
  variantId   BigInt
  productName String
  color       String
  unit        String
  quantity    Decimal  @db.Decimal(14, 2)
  unitCents   Int      @default(0)
  amountCents Int      @default(0)
  createdAt   DateTime @default(now())

  order   PurchaseOrder  @relation(fields: [orderId], references: [id])
  product Product        @relation(fields: [productId], references: [id])
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@index([tenantId])
  @@index([orgId])
  @@index([orderId])
}

model ReturnOrder {
  id               String           @id @default(cuid())
  tenantId         String?          @map("tenant_id")
  orgId            String
  no               String
  customerId       BigInt
  salesOrderId     BigInt?
  warehouseId      String?
  orderDate        DateTime
  returnCents      Int              @default(0)
  receivedToPrepay Boolean          @default(false)
  state            ReturnOrderState @default(pending)
  remark           String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  customer  Customer          @relation(fields: [customerId], references: [id])
  salesOrder SalesOrder?      @relation(fields: [salesOrderId], references: [id])
  warehouse Warehouse?        @relation(fields: [warehouseId], references: [id])
  items     ReturnOrderItem[]

  @@index([tenantId])
  @@unique([orgId, no])
  @@index([orgId, customerId, orderDate])
  @@index([orgId, salesOrderId])
}

model ReturnOrderItem {
  id          String   @id @default(cuid())
  tenantId    String?  @map("tenant_id")
  orgId       String?  @map("org_id")
  orderId     String
  productId   BigInt
  variantId   BigInt
  productName String
  color       String
  unit        String
  quantity    Decimal  @db.Decimal(14, 2)
  unitCents   Int      @default(0)
  amountCents Int      @default(0)
  createdAt   DateTime @default(now())

  order   ReturnOrder    @relation(fields: [orderId], references: [id])
  product Product        @relation(fields: [productId], references: [id])
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@index([tenantId])
  @@index([orgId])
  @@index([orderId])
}

model Message {
  id        String        @id @default(cuid())
  tenantId  String?       @map("tenant_id")
  orgId     String
  type      MessageType
  status    MessageStatus @default(unread)
  title     String
  content   String
  refType   String?
  refId     String?
  createdAt DateTime      @default(now())
  readAt    DateTime?

  organization Organization @relation(fields: [orgId], references: [id])

  @@index([tenantId])
  @@index([orgId, status, createdAt])
}

model ImportExportTask {
  id          String         @id @default(cuid())
  tenantId    String?        @map("tenant_id")
  orgId       String
  type        ImportTaskType
  status      TaskStatus     @default(pending)
  fileName    String?
  fileUrl     String?
  totalRows   Int            @default(0)
  successRows Int            @default(0)
  failedRows  Int            @default(0)
  errorText   String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  organization Organization @relation(fields: [orgId], references: [id])

  @@index([tenantId])
  @@index([orgId, type, createdAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String?  @map("tenant_id")
  orgId     String
  actorId   String?
  action    String
  entity    String
  entityId  String?
  before    Json?
  after     Json?
  createdAt DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id])

  @@index([tenantId])
  @@index([orgId, entity, entityId])
  @@index([orgId, createdAt])
}
