.org-switch-page {
  min-height: 100vh;
  background: #f4f7fb;
  color: #172033;
}

.org-scroll {
  height: 100vh;
}

.org-content {
  padding: 24rpx 24rpx 148rpx;
}

.search-card {
  height: 76rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  border: 1rpx solid #d8e5f6;
  border-radius: 16rpx;
  background: #ffffff;
}

.search-input {
  min-width: 0;
  flex: 1;
  height: 72rpx;
  color: #172033;
  font-size: 25rpx;
  line-height: 72rpx;
}

.input-placeholder {
  color: #98a2b3;
}

.org-list {
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.org-card {
  min-height: 142rpx;
  padding: 22rpx 22rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
  border: 1rpx solid #d8e5f6;
  border-radius: 22rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(13, 31, 61, 0.05);
}

.org-card-selected {
  border-color: #aee6ce;
  background: #fbfffd;
}

.org-main {
  min-width: 0;
  flex: 1;
}

.org-name {
  color: #172033;
  font-size: 29rpx;
  font-weight: 900;
  line-height: 40rpx;
}

.org-desc,
.org-meta {
  margin-top: 6rpx;
  color: #667085;
  font-size: 23rpx;
  line-height: 32rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.org-meta {
  color: #98a2b3;
}

.org-pill {
  flex: 0 0 auto;
  height: 40rpx;
  padding: 0 16rpx;
  display: flex;
  align-items: center;
  border-radius: 999rpx;
  font-size: 21rpx;
  font-weight: 900;
}

.org-pill-success {
  border: 1rpx solid #aee6ce;
  background: #eafaf3;
  color: #0e8a62;
}

.org-pill-primary {
  border: 1rpx solid #c9ddff;
  background: #eaf3ff;
  color: #2e7bef;
}

.empty-state {
  margin-top: 32rpx;
  padding: 52rpx 24rpx;
  border: 1rpx dashed #d8e5f6;
  border-radius: 22rpx;
  background: #ffffff;
  text-align: center;
}

.empty-title {
  color: #172033;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 42rpx;
}

.empty-desc {
  margin-top: 8rpx;
  color: #667085;
  font-size: 24rpx;
  line-height: 36rpx;
}

.bottom-actions {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 20;
  min-height: 108rpx;
  padding: 14rpx 24rpx calc(14rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  gap: 18rpx;
  border-top: 1rpx solid #e6ecf5;
  background: #ffffff;
}

.bottom-btn {
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 14rpx;
  font-size: 28rpx;
  font-weight: 900;
}

.bottom-btn-secondary {
  flex: 0 0 184rpx;
  border: 1rpx solid #d8e5f6;
  background: #ffffff;
  color: #2e7bef;
}

.bottom-btn-primary {
  flex: 1;
  background: #2e7bef;
  color: #ffffff;
}
