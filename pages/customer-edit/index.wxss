.customer-edit-page {
  min-height: 100vh;
  background: #f4f7fb;
  color: #172033;
}

.edit-scroll {
  height: 100vh;
}

.edit-content {
  padding: 24rpx 24rpx 148rpx;
}

.edit-action-row {
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.edit-title {
  color: #172033;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 44rpx;
}

.import-btn {
  width: 112rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 14rpx;
  background: #2e7bef;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 800;
}

.edit-card {
  margin-top: 20rpx;
  padding: 26rpx 28rpx;
  border: 1rpx solid #d8e5f6;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(13, 31, 61, 0.05);
}

.edit-card:first-of-type {
  margin-top: 8rpx;
}

.card-title {
  color: #1d2129;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 44rpx;
}

.card-desc {
  margin-top: 8rpx;
  color: #667085;
  font-size: 24rpx;
  line-height: 36rpx;
}

.form-list {
  margin-top: 18rpx;
}

.form-row {
  min-height: 88rpx;
  display: flex;
  align-items: center;
  border-top: 1rpx solid #d8e5f6;
}

.form-row:first-child {
  border-top: 0;
}

.form-row-tall {
  min-height: 116rpx;
  align-items: flex-start;
  padding-top: 24rpx;
}

.form-label {
  flex: 0 0 154rpx;
  color: #1d2129;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 40rpx;
}

.form-input,
.form-picker-value {
  min-width: 0;
  flex: 1;
  height: 72rpx;
  color: #172033;
  font-size: 28rpx;
  line-height: 72rpx;
}

.form-textarea {
  min-width: 0;
  flex: 1;
  height: 92rpx;
  padding-top: 2rpx;
  color: #172033;
  font-size: 28rpx;
  line-height: 40rpx;
}

.input-placeholder {
  color: #98a2b3;
  font-weight: 400;
}

.form-chevron {
  width: 28rpx;
  color: #98a2b3;
  font-size: 32rpx;
  line-height: 1;
  text-align: right;
}

.rule-tags {
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.rule-tag {
  height: 52rpx;
  padding: 0 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 800;
}

.rule-tag-primary {
  border: 1rpx solid #d8e5f6;
  background: #f2f7ff;
  color: #2e7bef;
}

.rule-tag-warning {
  border: 1rpx solid #f4c28b;
  background: #fff7e8;
  color: #d77a00;
}

.rule-copy {
  margin-top: 8rpx;
  color: #667085;
  font-size: 24rpx;
  line-height: 34rpx;
}

.bottom-actions {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 20;
  min-height: 108rpx;
  padding: 14rpx 24rpx calc(14rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  gap: 18rpx;
  border-top: 1rpx solid #e6ecf5;
  background: #ffffff;
}

.bottom-btn {
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 14rpx;
  font-size: 28rpx;
  font-weight: 800;
}

.bottom-btn-secondary {
  flex: 0 0 184rpx;
  border: 1rpx solid #d8e5f6;
  background: #ffffff;
  color: #2e7bef;
}

.bottom-btn-primary {
  flex: 1;
  background: #2e7bef;
  color: #ffffff;
}
