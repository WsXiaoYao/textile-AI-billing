<view class="warehouse-edit-page">
  <scroll-view class="edit-scroll" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="edit-content">
      <view class="edit-card">
        <view class="card-title">基础信息</view>
        <view class="card-desc">默认仓不可删除，已被业务单据使用的仓库只允许停用。</view>

        <view class="form-list">
          <view class="form-row">
            <view class="form-label">仓库名称</view>
            <input class="form-input" value="{{form.name}}" placeholder="请输入仓库名称" placeholder-class="input-placeholder" maxlength="50" bindinput="onNameInput" />
          </view>
          <view class="form-row">
            <view class="form-label">仓管</view>
            <input class="form-input" value="{{form.keeper}}" placeholder="请输入仓管姓名" placeholder-class="input-placeholder" maxlength="30" bindinput="onKeeperInput" />
          </view>
          <view class="form-row">
            <view class="form-label">地址</view>
            <input class="form-input" value="{{form.address}}" placeholder="请输入仓库地址" placeholder-class="input-placeholder" maxlength="120" bindinput="onAddressInput" />
          </view>
          <picker mode="selector" range="{{defaultOptions}}" value="{{defaultIndex}}" bindchange="onDefaultChange">
            <view class="form-row">
              <view class="form-label">是否默认仓</view>
              <view class="form-picker-value">{{defaultOptions[defaultIndex]}}</view>
              <view class="form-chevron">›</view>
            </view>
          </picker>
          <picker mode="selector" range="{{statusOptions}}" value="{{statusIndex}}" bindchange="onStatusChange">
            <view class="form-row">
              <view class="form-label">仓库状态</view>
              <view class="form-picker-value">{{statusOptions[statusIndex]}}</view>
              <view class="form-chevron">›</view>
            </view>
          </picker>
        </view>
      </view>

      <view class="edit-card">
        <view class="card-title">业务规则</view>
        <view class="rule-desc">仓库会影响采购、销售、退货和库存的归属与权限。</view>
        <view class="rule-list">
          <view class="rule-item">1. 销售、采购、退货默认读取默认仓。</view>
          <view class="rule-item">2. 默认仓不可停用。</view>
          <view class="rule-item">3. 停用仓库不会出现在新业务的仓库选择中。</view>
        </view>
      </view>
    </view>
  </scroll-view>

  <view class="bottom-actions">
    <view wx:if="{{showStatusToggle}}" class="bottom-btn bottom-btn-warning" bindtap="onToggleStatusTap">{{toggleText}}</view>
    <view class="bottom-btn bottom-btn-primary {{showStatusToggle ? '' : 'bottom-btn-full'}}" bindtap="onSaveTap">保存仓库</view>
  </view>
</view>
