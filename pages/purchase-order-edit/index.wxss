.purchase-edit-page {
  min-height: 100vh;
  background: #f4f7fb;
  color: #172033;
}

.edit-scroll {
  height: 100vh;
}

.edit-content {
  padding: 24rpx 24rpx 148rpx;
}

.edit-card {
  margin-top: 20rpx;
  padding: 26rpx 28rpx;
  border: 1rpx solid #d8e5f6;
  border-radius: 22rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(13, 31, 61, 0.05);
}

.edit-card:first-child {
  margin-top: 0;
}

.card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.card-title {
  color: #172033;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 44rpx;
}

.form-list,
.summary-list {
  margin-top: 18rpx;
}

.form-row {
  min-height: 88rpx;
  display: flex;
  align-items: center;
  border-top: 1rpx solid #d8e5f6;
}

.form-row:first-child {
  border-top: 0;
}

.form-row-tall {
  min-height: 116rpx;
  align-items: flex-start;
  padding-top: 24rpx;
}

.form-label {
  flex: 0 0 150rpx;
  color: #172033;
  font-size: 27rpx;
  font-weight: 800;
  line-height: 40rpx;
}

.form-value,
.form-textarea {
  min-width: 0;
  flex: 1;
  color: #172033;
  font-size: 27rpx;
  font-weight: 800;
}

.form-value {
  height: 72rpx;
  line-height: 72rpx;
}

.form-textarea {
  height: 92rpx;
  padding-top: 2rpx;
  line-height: 40rpx;
}

.form-chevron {
  width: 28rpx;
  color: #98a2b3;
  font-size: 32rpx;
  line-height: 1;
  text-align: right;
}

.input-placeholder {
  color: #98a2b3;
  font-weight: 400;
}

.line-list {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.line-card {
  position: relative;
  padding: 20rpx;
  border: 1rpx solid #d8e5f6;
  border-radius: 18rpx;
  background: #fbfdff;
}

.remove-line {
  position: absolute;
  top: -32rpx;
  right: -32rpx;
  width: 64rpx;
  height: 64rpx;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 0;
  border-radius: 50%;
  background: transparent;
  color: #d94a55;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1;
}

.remove-line::before {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  width: 32rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid #ffb7bd;
  border-radius: 50%;
  background: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(217, 74, 85, 0.12);
  content: "";
}

.remove-line {
  text-indent: -999rpx;
}

.remove-line::after {
  position: absolute;
  left: 16rpx;
  top: 14rpx;
  width: 32rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #d94a55;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 30rpx;
  text-indent: 0;
  content: "×";
}

.line-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  padding-right: 12rpx;
}

.line-title-wrap {
  min-width: 0;
  flex: 1;
}

.product-picker {
  min-width: 0;
  height: 46rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.line-name {
  min-width: 0;
  max-width: 330rpx;
  color: #172033;
  font-size: 27rpx;
  font-weight: 900;
  line-height: 38rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.picker-arrow {
  flex: 0 0 auto;
  color: #98a2b3;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1;
}

.line-stock {
  margin-top: 4rpx;
  color: #667085;
  font-size: 22rpx;
  line-height: 30rpx;
}

.line-side {
  flex: 0 0 128rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.line-amount {
  max-width: 138rpx;
  color: #d94a55;
  font-size: 27rpx;
  font-weight: 900;
  line-height: 38rpx;
  text-align: right;
  overflow-wrap: break-word;
}

.line-controls {
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.color-chip {
  width: 158rpx;
  height: 58rpx;
  padding: 0 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  border-radius: 999rpx;
  background: #eaf3ff;
  color: #2e7bef;
  font-size: 23rpx;
  font-weight: 900;
}

.qty-control {
  flex: 0 0 236rpx;
  height: 62rpx;
  display: flex;
  align-items: center;
  border: 1rpx solid #d8e5f6;
  border-radius: 999rpx;
  background: #ffffff;
  overflow: hidden;
}

.qty-btn {
  flex: 0 0 64rpx;
  height: 62rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #667085;
  font-size: 24rpx;
  font-weight: 900;
}

.qty-input {
  min-width: 0;
  flex: 1;
  height: 60rpx;
  color: #172033;
  font-size: 27rpx;
  font-weight: 900;
  line-height: 60rpx;
  text-align: center;
}

.line-unit {
  flex: 0 0 42rpx;
  color: #667085;
  font-size: 23rpx;
  font-weight: 800;
  line-height: 36rpx;
  text-align: center;
}

.price-box {
  flex: 0 0 124rpx;
  height: 62rpx;
  padding: 0 10rpx;
  display: flex;
  align-items: center;
  border: 1rpx solid #d8e5f6;
  border-radius: 12rpx;
  background: #ffffff;
  color: #667085;
  font-size: 22rpx;
  font-weight: 800;
  box-sizing: border-box;
}

.price-input {
  min-width: 0;
  flex: 1;
  height: 60rpx;
  color: #172033;
  font-size: 23rpx;
  font-weight: 900;
  line-height: 60rpx;
}

.add-line-wide {
  height: 70rpx;
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx dashed #9fc6ff;
  border-radius: 16rpx;
  background: #f4f9ff;
  color: #2e7bef;
  font-size: 26rpx;
  font-weight: 900;
}

.total-row,
.summary-row {
  min-height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-top: 1rpx solid #edf1f5;
  color: #172033;
  font-size: 26rpx;
  font-weight: 800;
  gap: 20rpx;
}

.total-row {
  margin-top: 18rpx;
}

.total-amount,
.summary-danger {
  color: #d94a55;
  font-weight: 900;
}

.summary-muted {
  color: #667085;
  font-size: 24rpx;
  font-weight: 800;
}

.bottom-actions {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 20;
  min-height: 108rpx;
  padding: 14rpx 24rpx calc(14rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  gap: 18rpx;
  border-top: 1rpx solid #e6ecf5;
  background: #ffffff;
}

.bottom-btn {
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 14rpx;
  font-size: 28rpx;
  font-weight: 900;
}

.bottom-btn-secondary {
  flex: 0 0 184rpx;
  border: 1rpx solid #d8e5f6;
  background: #ffffff;
  color: #2e7bef;
}

.bottom-btn-primary {
  flex: 1;
  background: #2e7bef;
  color: #ffffff;
}

.selector-layer {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 80;
}

.selector-backdrop {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  opacity: 0;
  background: rgba(23, 32, 51, 0.52);
  transition: opacity 220ms ease-out;
}

.selector-layer-active .selector-backdrop {
  opacity: 1;
}

.selector-panel {
  position: absolute;
  right: 0;
  bottom: 0;
  left: 0;
  height: 82vh;
  max-height: 1120rpx;
  display: flex;
  flex-direction: column;
  border-top-left-radius: 28rpx;
  border-top-right-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 -18rpx 54rpx rgba(23, 32, 51, 0.18);
  overflow: hidden;
  transform: translateY(100%);
  transition: transform 220ms cubic-bezier(0.2, 0.8, 0.2, 1);
  will-change: transform;
}

.selector-layer-active .selector-panel {
  transform: translateY(0);
}

.selector-handle {
  width: 72rpx;
  height: 6rpx;
  margin: 18rpx auto 6rpx;
  border-radius: 999rpx;
  background: #d8e5f6;
}

.selector-header {
  height: 74rpx;
  padding: 0 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.selector-title {
  color: #172033;
  font-size: 31rpx;
  font-weight: 900;
  line-height: 42rpx;
}

.selector-cancel {
  color: #667085;
  font-size: 25rpx;
  font-weight: 800;
  line-height: 36rpx;
}

.selector-current {
  min-height: 76rpx;
  margin: 0 28rpx 16rpx;
  padding: 14rpx 18rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  border-radius: 16rpx;
  background: #f8fafc;
}

.current-label {
  flex: 0 0 auto;
  color: #98a2b3;
  font-size: 21rpx;
  line-height: 30rpx;
}

.current-main {
  min-width: 0;
  flex: 1;
  color: #172033;
  font-size: 23rpx;
  font-weight: 800;
  line-height: 32rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.current-amount {
  flex: 0 0 auto;
  color: #d94a55;
  font-size: 23rpx;
  font-weight: 900;
  line-height: 32rpx;
}

.selector-search {
  height: 72rpx;
  margin: 0 28rpx 14rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  border: 1rpx solid #d8e5f6;
  border-radius: 16rpx;
  background: #fbfdff;
}

.selector-input {
  min-width: 0;
  flex: 1;
  height: 68rpx;
  color: #172033;
  font-size: 25rpx;
  line-height: 68rpx;
}

.selector-body {
  min-height: 0;
  flex: 1;
  padding: 0 28rpx calc(26rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.selector-product {
  padding: 22rpx 0;
  border-top: 1rpx solid #edf1f5;
}

.selector-product:first-child {
  border-top: 0;
}

.selector-product-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.selector-product-name {
  min-width: 0;
  color: #172033;
  font-size: 29rpx;
  font-weight: 900;
  line-height: 40rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.selector-product-tag {
  flex: 0 0 auto;
  height: 34rpx;
  padding: 0 12rpx;
  display: flex;
  align-items: center;
  border-radius: 999rpx;
  background: #eaf3ff;
  color: #2e7bef;
  font-size: 21rpx;
  font-weight: 900;
}

.selector-product-meta {
  margin-top: 4rpx;
  color: #98a2b3;
  font-size: 22rpx;
  line-height: 30rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.selector-variants {
  margin-top: 16rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.variant-option {
  position: relative;
  width: calc((100% - 14rpx) / 2);
  min-height: 82rpx;
  padding: 14rpx 16rpx;
  box-sizing: border-box;
  border: 1rpx solid #d8e5f6;
  border-radius: 16rpx;
  background: #fbfdff;
}

.variant-option-active {
  border-color: #2e7bef;
  background: #f4f9ff;
}

.variant-main {
  min-width: 0;
}

.variant-color {
  color: #172033;
  font-size: 25rpx;
  font-weight: 900;
  line-height: 34rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.variant-meta {
  margin-top: 4rpx;
  color: #667085;
  font-size: 21rpx;
  line-height: 30rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.variant-selected {
  position: absolute;
  right: 10rpx;
  top: 10rpx;
  height: 30rpx;
  padding: 0 10rpx;
  display: flex;
  align-items: center;
  border-radius: 999rpx;
  background: #eafaf3;
  color: #0e8a62;
  font-size: 19rpx;
  font-weight: 900;
  line-height: 1;
}

.selector-footer,
.selector-empty {
  padding: 26rpx 0;
  color: #98a2b3;
  font-size: 23rpx;
  line-height: 34rpx;
  text-align: center;
}
