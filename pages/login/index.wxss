page {
  background: #f1f5fb;
}

.login-page {
  min-height: 100vh;
  padding: 64rpx 32rpx 48rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #2f7df6 0%, #2f7df6 260rpx, #f1f5fb 260rpx, #f1f5fb 100%);
}

.login-hero {
  display: flex;
  align-items: center;
  gap: 24rpx;
  color: #ffffff;
}

.brand-mark {
  width: 88rpx;
  height: 88rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.18);
  border: 1rpx solid rgba(255, 255, 255, 0.32);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: 800;
}

.brand-copy {
  min-width: 0;
  flex: 1;
}

.brand-name {
  font-size: 42rpx;
  line-height: 1.25;
  font-weight: 800;
}

.brand-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: rgba(255, 255, 255, 0.82);
}

.login-card {
  margin-top: 54rpx;
  padding: 34rpx 32rpx;
  border-radius: 16rpx;
  background: #ffffff;
  border: 1rpx solid #d7e4f5;
  box-shadow: 0 14rpx 34rpx rgba(31, 83, 141, 0.12);
}

.card-title {
  font-size: 34rpx;
  line-height: 1.35;
  font-weight: 800;
  color: #1f2a3d;
}

.card-desc {
  margin-top: 14rpx;
  font-size: 25rpx;
  line-height: 1.65;
  color: #66748a;
}

.dev-tip {
  margin-top: 22rpx;
  padding: 18rpx 20rpx;
  border-radius: 12rpx;
  background: #fff8e6;
  border: 1rpx solid #ffe1a6;
  color: #8a5a00;
  font-size: 24rpx;
  line-height: 1.55;
}

.primary-btn,
.ghost-btn,
.plain-btn {
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.primary-btn {
  margin-top: 36rpx;
  color: #ffffff;
  background: #2f7df6;
}

.primary-btn[disabled] {
  color: rgba(255, 255, 255, 0.8);
  background: #8db8ff;
}

.ghost-btn {
  margin-top: 20rpx;
  color: #2f7df6;
  background: #f5f9ff;
  border: 1rpx solid #cfe1fb;
}

.plain-btn {
  margin-top: 20rpx;
  color: #66748a;
  background: #ffffff;
}
