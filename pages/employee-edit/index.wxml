<view class="employee-edit-page">
  <scroll-view class="edit-scroll" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="edit-content">
      <view class="edit-card">
        <view class="card-title">基础信息</view>

        <view class="form-list">
          <view class="form-row">
            <view class="form-label">用户名</view>
            <input class="form-input" value="{{form.name}}" placeholder="请输入员工姓名" placeholder-class="input-placeholder" maxlength="30" bindinput="onNameInput" />
          </view>

          <view class="form-row">
            <view class="form-label">手机号</view>
            <input class="form-input" type="number" value="{{form.phone}}" placeholder="请输入手机号" placeholder-class="input-placeholder" maxlength="11" bindinput="onPhoneInput" />
          </view>

          <view class="form-row form-row-roles">
            <view class="form-label">角色</view>
            <view class="role-select">
              <view class="role-summary">{{form.roleName}}</view>
              <view class="role-chip-row">
                <block wx:for="{{roles}}" wx:key="id">
                  <view
                    class="role-chip {{item.selected ? 'role-chip-active' : ''}}"
                    data-id="{{item.id}}"
                    bindtap="onRoleToggle"
                  >{{item.name}}</view>
                </block>
              </view>
            </view>
          </view>

          <picker mode="selector" range="{{statusOptions}}" range-key="label" value="{{statusIndex}}" bindchange="onStatusChange">
            <view class="form-row">
              <view class="form-label">员工状态</view>
              <view class="form-picker-value">{{statusOptions[statusIndex].label}}</view>
              <view class="form-chevron">›</view>
            </view>
          </picker>

          <picker mode="selector" range="{{warehouseOptions}}" range-key="label" value="{{warehouseIndex}}" bindchange="onWarehouseChange">
            <view class="form-row">
              <view class="form-label">绑定仓库</view>
              <view class="form-picker-value">{{form.warehouseText}}</view>
              <view class="form-chevron">›</view>
            </view>
          </picker>

          <view class="form-row form-row-tall">
            <view class="form-label">备注</view>
            <textarea class="form-textarea" value="{{form.remark}}" placeholder="默认可见全部组织数据。" placeholder-class="input-placeholder" maxlength="120" bindinput="onRemarkInput" />
          </view>
        </view>
      </view>

      <view class="edit-card">
        <view class="card-head">
          <view class="card-title">权限提醒</view>
          <view class="role-link" bindtap="onRolePermissionTap">查看角色</view>
        </view>
        <view class="rule-desc">员工可拥有多个角色，系统会合并菜单权限；仓库权限仅影响采购、库存、仓库等仓库维度数据。</view>
        <view class="rule-list">
          <view class="rule-item">1. 多角色权限取并集，例如采购 + 仓管。</view>
          <view class="rule-item">2. 员工可绑定多个仓库。</view>
          <view class="rule-item">3. 禁用后员工需重新登录。</view>
        </view>
      </view>
    </view>
  </scroll-view>

  <view class="bottom-actions">
    <view wx:if="{{showDisable}}" class="bottom-btn bottom-btn-warning" bindtap="onDisableTap">禁用员工</view>
    <view class="bottom-btn bottom-btn-primary {{showDisable ? '' : 'bottom-btn-full'}}" bindtap="onSaveTap">{{loading ? '保存中' : '保存员工'}}</view>
  </view>
</view>
