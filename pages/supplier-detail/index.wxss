.supplier-detail-page {
  min-height: 100vh;
  background: #f4f7fb;
  color: #172033;
}

.detail-scroll {
  height: 100vh;
}

.detail-content {
  padding: 24rpx 24rpx 148rpx;
}

.supplier-card,
.record-card {
  border: 1rpx solid #d8e5f6;
  border-radius: 22rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(13, 31, 61, 0.05);
}

.supplier-card {
  padding: 26rpx 28rpx;
}

.supplier-head {
  position: relative;
  min-height: 160rpx;
  padding-right: 112rpx;
}

.supplier-copy {
  min-width: 0;
}

.supplier-title-row {
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.supplier-name {
  min-width: 0;
  color: #172033;
  font-size: 31rpx;
  font-weight: 900;
  line-height: 42rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.supplier-chip {
  flex: 0 0 auto;
  height: 38rpx;
  padding: 0 14rpx;
  display: flex;
  align-items: center;
  border-radius: 999rpx;
  font-size: 21rpx;
  font-weight: 900;
}

.chip-success {
  border: 1rpx solid #aee6ce;
  background: #eafaf3;
  color: #0e8a62;
}

.chip-muted {
  background: #f4f7fb;
  color: #667085;
}

.supplier-desc,
.supplier-meta {
  margin-top: 10rpx;
  color: #667085;
  font-size: 24rpx;
  line-height: 34rpx;
}

.supplier-actions {
  position: absolute;
  top: 0;
  right: 0;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.edit-btn,
.call-btn {
  width: 88rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 1;
}

.edit-btn {
  border: 1rpx solid #b9d7ff;
  background: #ffffff;
  color: #2e7bef;
}

.call-btn {
  background: #2e7bef;
  color: #ffffff;
}

.record-card {
  margin-top: 20rpx;
  padding: 26rpx 28rpx;
}

.card-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.card-title {
  color: #172033;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 44rpx;
}

.card-desc {
  margin-top: 6rpx;
  color: #667085;
  font-size: 23rpx;
  line-height: 34rpx;
}

.record-count {
  flex: 0 0 auto;
  color: #667085;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 36rpx;
}

.record-table {
  margin-top: 18rpx;
}

.table-head,
.record-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.table-head {
  height: 44rpx;
  color: #98a2b3;
  font-size: 22rpx;
  line-height: 32rpx;
}

.record-row {
  min-height: 96rpx;
  border-top: 1rpx solid #edf1f5;
}

.col-name {
  min-width: 0;
  flex: 1;
}

.col-qty {
  flex: 0 0 72rpx;
  color: #172033;
  font-size: 23rpx;
  font-weight: 800;
  text-align: center;
}

.col-price,
.col-amount {
  flex: 0 0 104rpx;
  color: #172033;
  font-size: 23rpx;
  font-weight: 800;
  text-align: right;
  overflow-wrap: break-word;
}

.amount-danger,
.total-amount {
  color: #d94a55;
}

.record-no {
  color: #172033;
  font-size: 25rpx;
  font-weight: 900;
  line-height: 34rpx;
}

.record-meta {
  margin-top: 4rpx;
  color: #667085;
  font-size: 22rpx;
  line-height: 30rpx;
}

.empty-record {
  margin-top: 20rpx;
  padding: 22rpx;
  border: 1rpx dashed #d8e5f6;
  border-radius: 18rpx;
  background: #fbfdff;
  color: #667085;
  font-size: 24rpx;
  line-height: 36rpx;
  text-align: center;
}

.total-row {
  height: 74rpx;
  margin-top: 14rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-top: 1rpx solid #edf1f5;
  color: #172033;
  font-size: 27rpx;
  font-weight: 900;
}

.bottom-actions {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 20;
  min-height: 108rpx;
  padding: 14rpx 24rpx calc(14rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  gap: 18rpx;
  border-top: 1rpx solid #e6ecf5;
  background: #ffffff;
}

.bottom-btn {
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 14rpx;
  font-size: 28rpx;
  font-weight: 900;
}

.bottom-btn-secondary {
  flex: 0 0 184rpx;
  border: 1rpx solid #d8e5f6;
  background: #ffffff;
  color: #2e7bef;
}

.bottom-btn-primary {
  flex: 1;
  background: #2e7bef;
  color: #ffffff;
}
