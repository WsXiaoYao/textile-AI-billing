<view class="purchase-detail-page return-detail-page">
  <scroll-view class="detail-scroll" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="detail-content">
      <view class="detail-card">
        <view class="card-title">基础信息</view>
        <view class="info-list">
          <view class="info-row">
            <view class="info-label">退货单号</view>
            <view class="info-value">{{order.no}}</view>
          </view>
          <view class="info-row">
            <view class="info-label">客户</view>
            <view class="info-value">{{order.customerName}}</view>
          </view>
          <view class="info-row" wx:if="{{order.salesOrderId}}" bindtap="onSalesOrderTap">
            <view class="info-label">来源销售单</view>
            <view class="info-value info-link">{{order.salesOrderNo}}</view>
          </view>
          <view class="info-row">
            <view class="info-label">日期</view>
            <view class="info-value">{{order.date}}</view>
          </view>
          <view class="info-row">
            <view class="info-label">退款金额</view>
            <view class="info-value amount-danger">{{order.refundText}}</view>
          </view>
          <view class="info-row">
            <view class="info-label">计入预收</view>
            <view class="info-value">{{order.returnToPrepay ? '是' : '否'}}</view>
          </view>
          <view class="return-notice" wx:if="{{order.returnToPrepay}}">
            退款金额会转入客户预收款，不再生成线下退款处理。
          </view>
          <view class="info-row">
            <view class="info-label">仓库</view>
            <view class="info-value">{{order.warehouseName}}</view>
          </view>
          <view class="info-row">
            <view class="info-label">备注</view>
            <view class="info-value">{{order.remark || '无'}}</view>
          </view>
        </view>
      </view>

      <view class="detail-card">
        <view class="card-head">
          <view class="card-title">退货明细</view>
          <view class="item-count">{{order.itemCount}} 项</view>
        </view>
        <view class="detail-table">
          <view class="table-head">
            <view class="col-name">品名 / 颜色</view>
            <view class="col-qty">数量</view>
            <view class="col-price">单价</view>
            <view class="col-amount">金额</view>
          </view>
          <block wx:for="{{order.items}}" wx:key="id">
            <view class="detail-row">
              <view class="col-name">
                <view class="line-name">{{item.productName}}</view>
                <view class="line-meta">{{item.color}}</view>
              </view>
              <view class="col-qty">{{item.quantityText}}</view>
              <view class="col-price">{{item.unitPriceText}}</view>
              <view class="col-amount amount-danger">{{item.amountText}}</view>
            </view>
          </block>
        </view>
        <view class="total-row">
          <view>明细金额</view>
          <view class="total-amount">{{order.itemAmountText}}</view>
        </view>
      </view>

      <view class="detail-card">
        <view class="card-title">处理结果</view>
        <view class="summary-list">
          <view class="summary-row">
            <view>退货状态</view>
            <view class="status-text status-{{order.statusTone}}">{{order.statusText}}</view>
          </view>
          <view class="summary-row">
            <view>库存处理</view>
            <view class="summary-primary">已回写库存</view>
          </view>
          <view class="summary-row">
            <view>退款去向</view>
            <view>{{order.refundDirectionText}}</view>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>

  <view class="bottom-actions">
    <view class="bottom-btn bottom-btn-secondary" bindtap="onBackTap">返回</view>
    <button class="bottom-btn bottom-btn-plain share-button" open-type="share">分享</button>
    <view class="bottom-btn bottom-btn-primary" bindtap="onEditTap">编辑退货单</view>
  </view>
</view>
