.customers-page {
  min-height: 100vh;
  padding: 24rpx 24rpx calc(156rpx + env(safe-area-inset-bottom));
  background: #f4f7fb;
  box-sizing: border-box;
}

.summary-section {
  margin-top: 18rpx;
}

.customer-list {
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.customer-card-item {
  display: block;
  width: 100%;
}

.customer-list-footer {
  padding: 6rpx 0 24rpx;
  color: #98a2b3;
  font-size: 22rpx;
  line-height: 32rpx;
  text-align: center;
}

.customer-fab {
  position: fixed;
  right: 28rpx;
  bottom: calc(132rpx + env(safe-area-inset-bottom));
  z-index: 30;
  height: 72rpx;
  padding: 0 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: #2e7bef;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 800;
  box-shadow: 0 12rpx 28rpx rgba(46, 123, 239, 0.25);
}

.empty-state {
  margin-top: 56rpx;
  padding: 52rpx 32rpx;
  border: 1rpx dashed #d8e5f6;
  border-radius: 24rpx;
  background: #ffffff;
  text-align: center;
}

.empty-title {
  color: #172033;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 42rpx;
}

.empty-desc {
  margin-top: 10rpx;
  color: #667085;
  font-size: 24rpx;
  line-height: 36rpx;
}

.filter-layer {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 80;
}

.filter-backdrop {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  opacity: 0;
  background: rgba(23, 32, 51, 0.46);
  transition: opacity 240ms ease-out;
}

.filter-layer-active .filter-backdrop {
  opacity: 1;
}

.filter-drawer {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  width: 600rpx;
  max-width: 82vw;
  display: flex;
  flex-direction: column;
  background: #f6f7f9;
  border-top-left-radius: 28rpx;
  border-bottom-left-radius: 28rpx;
  box-shadow: -16rpx 0 48rpx rgba(23, 32, 51, 0.18);
  overflow: hidden;
  transform: translateX(100%);
  transition: transform 240ms cubic-bezier(0.2, 0.8, 0.2, 1);
  will-change: transform;
}

.filter-layer-active .filter-drawer {
  transform: translateX(0);
}

.filter-header {
  flex: 0 0 108rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 28rpx;
  background: #ffffff;
  border-bottom: 1rpx solid #edf1f5;
}

.filter-title {
  color: #172033;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 44rpx;
}

.filter-selected {
  color: #667085;
  font-size: 24rpx;
  line-height: 36rpx;
}

.filter-body {
  min-height: 0;
  flex: 1;
  box-sizing: border-box;
  padding: 24rpx 24rpx 144rpx;
}

.filter-section {
  margin-top: 20rpx;
  padding: 24rpx;
  border-radius: 20rpx;
  background: #ffffff;
}

.filter-section:first-child {
  margin-top: 0;
}

.filter-section-title {
  color: #172033;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 40rpx;
}

.filter-chip-grid {
  margin-top: 20rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx 14rpx;
}

.filter-chip {
  box-sizing: border-box;
  width: 160rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid transparent;
  border-radius: 16rpx;
  background: #f4f7fb;
  color: #1d2129;
  font-size: 25rpx;
  line-height: 1;
  white-space: nowrap;
}

.filter-chip-active {
  border-color: #2e7bef;
  background: #eaf3ff;
  color: #2e7bef;
  font-weight: 800;
}

.filter-footer {
  position: absolute;
  right: 0;
  bottom: 0;
  left: 0;
  box-sizing: border-box;
  height: 120rpx;
  display: flex;
  gap: 20rpx;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #edf1f5;
  background: #ffffff;
}

.filter-reset,
.filter-done {
  box-sizing: border-box;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1;
}

.filter-reset {
  flex: 0 0 196rpx;
  border: 1rpx solid #b9d7ff;
  background: #ffffff;
  color: #2e7bef;
}

.filter-done {
  flex: 1;
  background: #2e7bef;
  color: #ffffff;
}

.date-panel {
  width: 100%;
  height: 432rpx;
  overflow: hidden;
  background: #ffffff;
}

.date-panel-header {
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40rpx;
  background: #2e7bef;
  color: #ffffff;
}

.date-panel-link {
  width: 120rpx;
  color: #ffffff;
  font-size: 30rpx;
  line-height: 44rpx;
}

.date-panel-title {
  flex: 1;
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 800;
  line-height: 52rpx;
  text-align: center;
}

.date-panel-confirm {
  text-align: right;
}

.date-presets {
  display: flex;
  border-bottom: 1rpx solid #edf1f5;
}

.date-preset {
  position: relative;
  flex: 1;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #1d2129;
  font-size: 28rpx;
}

.date-preset-active {
  color: #0794b8;
  font-weight: 800;
}

.date-preset-active::after {
  position: absolute;
  right: 0;
  bottom: 0;
  left: 0;
  height: 6rpx;
  border-radius: 999rpx;
  background: #0794b8;
  content: "";
}

.date-native-range {
  margin: 32rpx 32rpx 0;
  overflow: hidden;
  border: 1rpx solid #d8e5f6;
  border-radius: 20rpx;
  background: #ffffff;
}

.date-range-picker {
  display: block;
}

.date-range-row {
  position: relative;
  box-sizing: border-box;
  height: 88rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #ffffff;
}

.date-range-row-first {
  border-bottom: 1rpx solid #edf1f5;
}

.date-range-copy {
  min-width: 0;
  flex: 1;
}

.date-native-label {
  color: #667085;
  font-size: 24rpx;
  line-height: 32rpx;
}

.date-native-value {
  margin-top: 2rpx;
  color: #1d2129;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 40rpx;
}

.date-range-chevron {
  flex: 0 0 36rpx;
  color: #98a2b3;
  font-size: 40rpx;
  line-height: 1;
  text-align: right;
}
