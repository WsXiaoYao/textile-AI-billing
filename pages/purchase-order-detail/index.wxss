.purchase-detail-page {
  min-height: 100vh;
  background: #f4f7fb;
  color: #172033;
}

.detail-scroll {
  height: 100vh;
}

.detail-content {
  padding: 24rpx 24rpx 148rpx;
}

.detail-card {
  margin-top: 20rpx;
  padding: 26rpx 28rpx;
  border: 1rpx solid #d8e5f6;
  border-radius: 22rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(13, 31, 61, 0.05);
}

.detail-card:first-child {
  margin-top: 0;
}

.card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.card-title {
  color: #172033;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 44rpx;
}

.item-count {
  color: #667085;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 36rpx;
}

.info-list,
.summary-list {
  margin-top: 18rpx;
}

.info-row,
.summary-row {
  min-height: 76rpx;
  display: flex;
  align-items: center;
  border-top: 1rpx solid #edf1f5;
  gap: 18rpx;
}

.info-row:first-child,
.summary-row:first-child {
  border-top: 0;
}

.info-label {
  flex: 0 0 142rpx;
  color: #667085;
  font-size: 25rpx;
  line-height: 36rpx;
}

.info-value {
  min-width: 0;
  flex: 1;
  color: #172033;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 38rpx;
}

.detail-table {
  margin-top: 18rpx;
}

.table-head,
.detail-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.table-head {
  height: 44rpx;
  color: #98a2b3;
  font-size: 22rpx;
  line-height: 32rpx;
}

.detail-row {
  min-height: 100rpx;
  border-top: 1rpx solid #edf1f5;
}

.col-name {
  min-width: 0;
  flex: 1;
}

.col-qty {
  flex: 0 0 76rpx;
  color: #172033;
  font-size: 23rpx;
  font-weight: 800;
  text-align: center;
}

.col-price,
.col-amount {
  flex: 0 0 104rpx;
  color: #172033;
  font-size: 23rpx;
  font-weight: 800;
  text-align: right;
  overflow-wrap: break-word;
}

.line-name {
  color: #172033;
  font-size: 25rpx;
  font-weight: 900;
  line-height: 34rpx;
}

.line-meta {
  margin-top: 4rpx;
  color: #667085;
  font-size: 22rpx;
  line-height: 30rpx;
}

.amount-danger,
.total-amount,
.summary-danger {
  color: #d94a55;
}

.summary-primary {
  color: #2e7bef;
}

.total-row,
.summary-row {
  justify-content: space-between;
  color: #172033;
  font-size: 26rpx;
  font-weight: 800;
}

.total-row {
  min-height: 72rpx;
  margin-top: 12rpx;
  display: flex;
  align-items: center;
  border-top: 1rpx solid #edf1f5;
}

.total-amount,
.summary-row > view:last-child {
  font-weight: 900;
}

.bottom-actions {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 20;
  min-height: 108rpx;
  padding: 14rpx 24rpx calc(14rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  gap: 18rpx;
  border-top: 1rpx solid #e6ecf5;
  background: #ffffff;
}

.bottom-btn {
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 14rpx;
  font-size: 28rpx;
  font-weight: 900;
}

.share-button {
  margin: 0;
  padding: 0;
  line-height: 80rpx;
}

.share-button::after {
  border: 0;
}

.bottom-btn-secondary,
.bottom-btn-plain {
  flex: 0 0 132rpx;
  border: 1rpx solid #d8e5f6;
  background: #ffffff;
  color: #2e7bef;
}

.bottom-btn-primary {
  flex: 1;
  background: #2e7bef;
  color: #ffffff;
}
