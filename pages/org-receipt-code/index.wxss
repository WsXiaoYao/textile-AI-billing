.receipt-page {
  min-height: 100vh;
  background: #f4f7fb;
  color: #172033;
}

.receipt-scroll {
  height: 100vh;
}

.receipt-content {
  padding: 24rpx 24rpx 148rpx;
}

.receipt-card {
  margin-top: 20rpx;
  padding: 26rpx 28rpx;
  border: 1rpx solid #d8e5f6;
  border-radius: 22rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(13, 31, 61, 0.05);
}

.receipt-card:first-child {
  margin-top: 0;
}

.card-title {
  color: #172033;
  font-size: 31rpx;
  font-weight: 900;
  line-height: 44rpx;
}

.card-desc {
  margin-top: 6rpx;
  color: #667085;
  font-size: 23rpx;
  line-height: 34rpx;
}

.upload-row {
  margin-top: 24rpx;
  display: flex;
  gap: 20rpx;
}

.upload-box {
  flex: 0 0 160rpx;
  height: 160rpx;
  border: 1rpx solid #d8e5f6;
  border-radius: 18rpx;
  background: #f4f9ff;
  overflow: hidden;
}

.receipt-image {
  width: 100%;
  height: 100%;
}

.upload-empty {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.upload-icon {
  width: 44rpx;
  height: 44rpx;
}

.upload-text {
  margin-top: 10rpx;
  color: #2e7bef;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 32rpx;
}

.note-field {
  min-width: 0;
  flex: 1;
}

.field-label {
  color: #667085;
  font-size: 23rpx;
  font-weight: 800;
  line-height: 34rpx;
}

.note-input {
  width: 100%;
  height: 120rpx;
  margin-top: 10rpx;
  padding: 16rpx 18rpx;
  border: 1rpx solid #d8e5f6;
  border-radius: 14rpx;
  color: #172033;
  font-size: 24rpx;
  line-height: 34rpx;
  background: #fbfdff;
}

.input-placeholder {
  color: #98a2b3;
}

.rule-list {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.rule-item {
  color: #667085;
  font-size: 24rpx;
  line-height: 36rpx;
}

.bottom-actions {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 20;
  min-height: 108rpx;
  padding: 14rpx 24rpx calc(14rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  gap: 18rpx;
  border-top: 1rpx solid #e6ecf5;
  background: #ffffff;
}

.bottom-btn {
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 14rpx;
  font-size: 28rpx;
  font-weight: 900;
}

.bottom-btn-secondary {
  flex: 0 0 184rpx;
  border: 1rpx solid #d8e5f6;
  background: #ffffff;
  color: #2e7bef;
}

.bottom-btn-primary {
  flex: 1;
  background: #2e7bef;
  color: #ffffff;
}
