.stock-page {
  min-height: 100vh;
  background: #f4f7fb;
  color: #172033;
}

.stock-scroll {
  height: 100vh;
}

.stock-content {
  padding: 24rpx 24rpx calc(32rpx + env(safe-area-inset-bottom));
}

.toolbar-card,
.summary-card,
.result-card {
  border: 1rpx solid #d8e5f6;
  border-radius: 22rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(13, 31, 61, 0.05);
}

.toolbar-card {
  padding: 14rpx;
}

.search-row {
  height: 72rpx;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  border-radius: 14rpx;
  background: #f8fafc;
}

.search-input {
  min-width: 0;
  flex: 1;
  height: 68rpx;
  color: #172033;
  font-size: 24rpx;
  line-height: 68rpx;
}

.search-placeholder {
  color: #98a2b3;
}

.query-row {
  height: 76rpx;
  margin-top: 12rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.query-picker {
  flex: 1;
  min-width: 0;
  height: 64rpx;
}

.query-picker-wide {
  flex: 1.32;
}

.query-action,
.quick-chip {
  height: 64rpx;
  min-width: 0;
  padding: 0 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid #d8e5f6;
  border-radius: 14rpx;
  background: #ffffff;
  color: #2e7bef;
  font-size: 23rpx;
  font-weight: 900;
  line-height: 1;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.quick-chip {
  flex: 0 0 112rpx;
}

.quick-chip-active {
  border-color: #2e7bef;
  background: #eaf3ff;
}

.summary-card,
.result-card {
  margin-top: 20rpx;
  padding: 24rpx;
}

.card-head,
.result-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.card-title {
  color: #172033;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 44rpx;
}

.card-desc {
  margin-top: 4rpx;
  color: #667085;
  font-size: 23rpx;
  line-height: 34rpx;
}

.summary-count {
  flex: 0 0 auto;
  color: #667085;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 36rpx;
}

.summary-metrics {
  margin-top: 20rpx;
  padding-bottom: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  border-bottom: 1rpx solid #edf1f5;
}

.summary-item {
  min-width: 180rpx;
  flex: 1 1 180rpx;
  padding: 14rpx 16rpx;
  border-radius: 16rpx;
  background: #f8fafc;
  box-sizing: border-box;
}

.summary-item-wide {
  min-width: 280rpx;
  flex-basis: 280rpx;
}

.summary-label {
  color: #667085;
  font-size: 22rpx;
  line-height: 30rpx;
}

.summary-value {
  margin-top: 4rpx;
  color: #172033;
  font-size: 29rpx;
  font-weight: 900;
  line-height: 38rpx;
  white-space: normal;
  word-break: break-all;
}

.amount-danger {
  color: #d94a55;
}

.amount-primary {
  color: #2e7bef;
}

.summary-chips {
  margin-top: 16rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.summary-chip {
  height: 38rpx;
  padding: 0 14rpx;
  display: flex;
  align-items: center;
  border-radius: 999rpx;
  font-size: 21rpx;
  font-weight: 900;
  line-height: 1;
}

.chip-warning {
  background: #fff6e5;
  color: #d77a00;
}

.chip-muted {
  background: #f4f7fb;
  color: #667085;
}

.chip-primary {
  background: #eaf3ff;
  color: #2e7bef;
}

.stock-list {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.stock-card {
  min-height: 148rpx;
  padding: 22rpx;
  display: flex;
  gap: 18rpx;
  border: 1rpx solid #d8e5f6;
  border-radius: 20rpx;
  background: #ffffff;
}

.stock-main {
  min-width: 0;
  flex: 1;
}

.stock-title-row {
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.stock-name {
  min-width: 0;
  color: #172033;
  font-size: 29rpx;
  font-weight: 900;
  line-height: 40rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.stock-badge {
  flex: 0 0 auto;
  height: 38rpx;
  padding: 0 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  font-size: 21rpx;
  font-weight: 900;
  line-height: 1;
}

.stock-badge-success {
  border: 1rpx solid #aee6ce;
  background: #eafaf3;
  color: #0e8a62;
}

.stock-badge-warning {
  border: 1rpx solid #f4c28b;
  background: #fff7e8;
  color: #d77a00;
}

.stock-badge-danger {
  border: 1rpx solid #f6b6bc;
  background: #fff0f2;
  color: #d94a55;
}

.stock-meta {
  margin-top: 8rpx;
  color: #667085;
  font-size: 23rpx;
  line-height: 32rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.stock-extra {
  min-height: 32rpx;
  margin-top: 10rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  color: #98a2b3;
  font-size: 22rpx;
  line-height: 32rpx;
}

.stock-side {
  flex: 0 0 132rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  justify-content: center;
}

.stock-side-label {
  color: #98a2b3;
  font-size: 22rpx;
  line-height: 30rpx;
}

.stock-side-value {
  margin-top: 4rpx;
  max-width: 136rpx;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 40rpx;
  text-align: right;
  overflow-wrap: break-word;
}

.stock-value-success {
  color: #0e8a62;
}

.stock-value-warning,
.stock-value-danger {
  color: #d94a55;
}

.list-footer {
  padding: 4rpx 0 20rpx;
  color: #98a2b3;
  font-size: 22rpx;
  line-height: 32rpx;
  text-align: center;
}

.empty-state {
  margin-top: 18rpx;
  padding: 52rpx 24rpx;
  border: 1rpx dashed #d8e5f6;
  border-radius: 20rpx;
  background: #ffffff;
  text-align: center;
}

.empty-title {
  color: #172033;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 42rpx;
}

.empty-desc {
  margin-top: 8rpx;
  color: #667085;
  font-size: 24rpx;
  line-height: 36rpx;
}

.filter-layer {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 80;
}

.filter-backdrop {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  opacity: 0;
  background: rgba(23, 32, 51, 0.46);
  transition: opacity 240ms ease-out;
}

.filter-layer-active .filter-backdrop {
  opacity: 1;
}

.filter-drawer {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  width: 600rpx;
  max-width: 82vw;
  display: flex;
  flex-direction: column;
  background: #f6f7f9;
  border-top-left-radius: 28rpx;
  border-bottom-left-radius: 28rpx;
  box-shadow: -16rpx 0 48rpx rgba(23, 32, 51, 0.18);
  overflow: hidden;
  transform: translateX(100%);
  transition: transform 240ms cubic-bezier(0.2, 0.8, 0.2, 1);
  will-change: transform;
}

.filter-layer-active .filter-drawer {
  transform: translateX(0);
}

.filter-header {
  flex: 0 0 108rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 28rpx;
  background: #ffffff;
  border-bottom: 1rpx solid #edf1f5;
}

.filter-title {
  color: #172033;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 44rpx;
}

.filter-selected {
  color: #667085;
  font-size: 24rpx;
  line-height: 36rpx;
}

.filter-body {
  min-height: 0;
  flex: 1;
  padding: 24rpx 24rpx 144rpx;
  box-sizing: border-box;
}

.filter-section {
  margin-top: 20rpx;
  padding: 24rpx;
  border-radius: 20rpx;
  background: #ffffff;
}

.filter-section:first-child {
  margin-top: 0;
}

.filter-section-title {
  color: #172033;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 40rpx;
}

.filter-chip-row {
  margin-top: 20rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx 14rpx;
}

.filter-chip {
  width: 160rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid transparent;
  border-radius: 16rpx;
  background: #f4f7fb;
  color: #1d2129;
  font-size: 25rpx;
  line-height: 1;
  white-space: nowrap;
}

.filter-chip-active {
  border-color: #2e7bef;
  background: #eaf3ff;
  color: #2e7bef;
  font-weight: 900;
}

.filter-footer {
  position: absolute;
  right: 0;
  bottom: 0;
  left: 0;
  height: 120rpx;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 20rpx;
  border-top: 1rpx solid #edf1f5;
  background: #ffffff;
}

.filter-reset,
.filter-done {
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1;
}

.filter-reset {
  flex: 0 0 196rpx;
  border: 1rpx solid #b9d7ff;
  background: #ffffff;
  color: #2e7bef;
}

.filter-done {
  flex: 1;
  background: #2e7bef;
  color: #ffffff;
}
