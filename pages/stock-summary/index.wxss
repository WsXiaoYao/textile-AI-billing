.stock-page {
  min-height: 100vh;
  background: #f4f7fb;
  color: #172033;
}

.stock-scroll {
  height: 100vh;
}

.stock-content {
  padding: 24rpx 24rpx calc(32rpx + env(safe-area-inset-bottom));
}

.summary-card {
  border: 1rpx solid #d8e5f6;
  border-radius: 22rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(13, 31, 61, 0.05);
}

.summary-card {
  margin-top: 20rpx;
  padding: 24rpx;
}

.result-section {
  margin-top: 24rpx;
}

.card-head,
.result-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.result-head {
  padding: 0 4rpx;
  align-items: center;
}

.card-title {
  color: #172033;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 44rpx;
}

.summary-count {
  flex: 0 0 auto;
  color: #667085;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 36rpx;
}

.summary-metrics {
  margin-top: 20rpx;
  padding-bottom: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  border-bottom: 1rpx solid #edf1f5;
}

.summary-item {
  min-width: 180rpx;
  flex: 1 1 180rpx;
  padding: 14rpx 16rpx;
  border-radius: 16rpx;
  background: #f8fafc;
  box-sizing: border-box;
}

.summary-item-wide {
  min-width: 100%;
  flex-basis: 100%;
}

.summary-item:first-child,
.summary-item:nth-child(2) {
  min-width: 0;
  flex-basis: calc(50% - 7rpx);
}

.summary-label {
  color: #667085;
  font-size: 22rpx;
  line-height: 30rpx;
}

.summary-value {
  margin-top: 4rpx;
  color: #172033;
  font-size: 29rpx;
  font-weight: 900;
  line-height: 38rpx;
  white-space: normal;
  word-break: break-all;
}

.amount-danger {
  color: #d94a55;
}

.amount-primary {
  color: #2e7bef;
}

.summary-chips {
  margin-top: 16rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.summary-chip {
  height: 38rpx;
  padding: 0 14rpx;
  display: flex;
  align-items: center;
  border-radius: 999rpx;
  font-size: 21rpx;
  font-weight: 900;
  line-height: 1;
}

.chip-warning {
  background: #fff6e5;
  color: #d77a00;
}

.chip-muted {
  background: #f4f7fb;
  color: #667085;
}

.chip-primary {
  background: #eaf3ff;
  color: #2e7bef;
}

.stock-list {
  margin-top: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.stock-card {
  min-height: 148rpx;
  padding: 22rpx;
  display: flex;
  gap: 14rpx;
  border: 1rpx solid #d8e5f6;
  border-radius: 22rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(13, 31, 61, 0.05);
}

.stock-main {
  min-width: 0;
  flex: 1;
}

.stock-title-row {
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.stock-name {
  min-width: 0;
  color: #172033;
  font-size: 29rpx;
  font-weight: 900;
  line-height: 40rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.stock-badge {
  flex: 0 0 auto;
  height: 38rpx;
  padding: 0 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  font-size: 21rpx;
  font-weight: 900;
  line-height: 1;
}

.stock-badge-success {
  border: 1rpx solid #aee6ce;
  background: #eafaf3;
  color: #0e8a62;
}

.stock-badge-warning {
  border: 1rpx solid #f4c28b;
  background: #fff7e8;
  color: #d77a00;
}

.stock-badge-danger {
  border: 1rpx solid #f6b6bc;
  background: #fff0f2;
  color: #d94a55;
}

.stock-meta {
  margin-top: 8rpx;
  color: #667085;
  font-size: 23rpx;
  line-height: 32rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.stock-extra {
  min-height: 32rpx;
  margin-top: 10rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  color: #98a2b3;
  font-size: 22rpx;
  line-height: 32rpx;
}

.stock-side {
  flex: 0 0 132rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  justify-content: center;
}

.stock-side-label {
  color: #98a2b3;
  font-size: 22rpx;
  line-height: 30rpx;
}

.stock-side-value {
  margin-top: 4rpx;
  max-width: 136rpx;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 40rpx;
  text-align: right;
  overflow-wrap: break-word;
}

.stock-value-success {
  color: #0e8a62;
}

.stock-value-warning,
.stock-value-danger {
  color: #d94a55;
}

.list-footer {
  padding: 4rpx 0 20rpx;
  color: #98a2b3;
  font-size: 22rpx;
  line-height: 32rpx;
  text-align: center;
}

.empty-state {
  margin-top: 18rpx;
  padding: 52rpx 24rpx;
  border: 1rpx dashed #d8e5f6;
  border-radius: 20rpx;
  background: #ffffff;
  text-align: center;
}

.empty-title {
  color: #172033;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 42rpx;
}

.empty-desc {
  margin-top: 8rpx;
  color: #667085;
  font-size: 24rpx;
  line-height: 36rpx;
}
