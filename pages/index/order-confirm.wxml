<view class="checkout-page">
  <scroll-view class="checkout-scroll" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="checkout-content">
      <view class="checkout-card customer-card">
        <view class="card-head">
          <view class="card-title">客户与单据</view>
          <view class="customer-tag">{{draft.customer.tag}}</view>
          <view class="customer-debt">
            <view class="debt-label">累计欠款</view>
            <view class="debt-value">{{draft.customerDebtText}}</view>
          </view>
        </view>

        <view class="info-row">
          <view class="info-label">客户</view>
          <view class="info-value info-strong">{{draft.customer.name}}</view>
        </view>
        <view class="info-row">
          <view class="info-label">电话</view>
          <view class="info-value info-muted">{{draft.customer.phone}}</view>
        </view>
        <view class="info-row info-row-address">
          <view class="info-label">地址</view>
          <view class="info-value info-muted">{{draft.customer.address}}</view>
        </view>
        <view class="info-row">
          <view class="info-label">仓库</view>
          <view class="info-value info-primary">{{draft.warehouse}}</view>
        </view>
      </view>

      <view class="checkout-card product-detail-card">
        <view class="card-title">产品明细</view>
        <view class="product-head">
          <view class="product-col-main">商品 / 颜色 / 库存</view>
          <view class="product-col-qty">数量</view>
          <view class="product-col-price">单价</view>
          <view class="product-col-amount">金额</view>
        </view>

        <block wx:for="{{draft.items}}" wx:key="id">
          <view class="product-row">
            <view class="product-main">
              <view class="product-name">{{item.name}}</view>
              <view class="product-meta">
                <text>{{item.color}}</text>
                <text class="{{item.stockQty <= 0 ? 'stock-danger' : ''}}">{{item.stockText}}</text>
              </view>
            </view>
            <view class="product-qty">{{item.quantityText}}</view>
            <view class="product-price">{{item.priceText}}</view>
            <view class="product-amount">{{item.amountText}}</view>
          </view>
        </block>
      </view>

      <view class="checkout-card">
        <view class="card-title">金额汇总</view>
        <view class="amount-row">
          <view>订单金额</view>
          <view class="amount-normal">{{draft.totalText}}</view>
        </view>
        <view class="amount-row">
          <view>优惠金额</view>
          <view class="amount-edit-value">
            <text class="amount-input-prefix">¥</text>
            <input
              class="discount-input"
              type="digit"
              value="{{discountInputValue}}"
              bindinput="onDiscountInput"
              bindblur="onDiscountBlur"
            />
          </view>
        </view>
        <view class="amount-row">
          <view>合同金额</view>
          <view class="amount-danger">{{draft.contractText}}</view>
        </view>

        <view class="prepaid-panel">
          <view class="amount-row compact">
            <view>预收款项</view>
            <view class="amount-success">{{draft.prepaidText}}</view>
          </view>
          <view class="amount-row compact">
            <view>使用预收款</view>
            <view class="amount-primary">{{draft.usePrepaidText}}</view>
          </view>
          <view class="amount-row compact">
            <view>未收金额</view>
            <view class="amount-danger">{{draft.unpaidText}}</view>
          </view>
          <view class="prepaid-note">提交后自动生成“冲销预收”收款记录</view>
        </view>
      </view>

      <view class="checkout-card">
        <view class="card-title">备注</view>
        <textarea
          class="remark-textarea"
          value="{{remark}}"
          placeholder="给客户或仓库的补充说明"
          placeholder-class="input-placeholder"
          maxlength="120"
          bindinput="onRemarkInput"
        />
      </view>

      <view class="checkout-card print-card">
        <view>
          <view class="card-title">打印与分享</view>
          <view class="card-desc">保存销售单后可继续单独打印。</view>
        </view>
        <view class="print-actions">
          <button class="print-btn secondary" bindtap="onShareTap">分享</button>
          <button class="print-btn primary" bindtap="onPrintTap">打印</button>
        </view>
      </view>
    </view>
  </scroll-view>

  <view class="checkout-bottom">
    <view class="bottom-amount">
      <view class="bottom-label">合同金额</view>
      <view class="bottom-value">{{draft.totalText}}</view>
    </view>
    <button class="bottom-btn secondary" bindtap="onBackToCartTap">返回购物车</button>
    <button class="bottom-btn primary {{submitting ? 'disabled' : ''}}" bindtap="onConfirmTap">确认下单</button>
  </view>
</view>
