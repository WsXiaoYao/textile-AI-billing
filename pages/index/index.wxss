}

.cart-line-amount {
  flex: 0 0 88rpx;
  color: #d94a55;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 40rpx;
  text-align: right;
}

.cart-remove {
  position: absolute;
  top: -36rpx;
  right: -40rpx;
  width: 80rpx;
  height: 80rpx;
  z-index: 30;
}

.cart-remove::before {
  position: absolute;
  top: 12rpx;
  left: 16rpx;
  width: 48rpx;
  height: 48rpx;
  border: 1rpx solid #ffb7bd;
  border-radius: 50%;
  background: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(217, 74, 85, 0.12);
  content: "";
}

.cart-remove::after {
  position: absolute;
  top: 12rpx;
  left: 16rpx;
  width: 48rpx;
  height: 48rpx;
  color: #d94a55;
  content: "×";
  font-size: 28rpx;
  font-weight: 900;
  line-height: 48rpx;
  text-align: center;
}

.cart-line-controls {
  margin-top: 28rpx;
