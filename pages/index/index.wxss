.order-page {
  min-height: 100vh;
  padding-bottom: 132rpx;
  background: #f5f8fc;
  color: #172033;
}

.order-hero {
  position: relative;
  height: 204rpx;
  overflow: hidden;
  background: #2f7df6;
  color: #ffffff;
}

.hero-accent {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  height: 60rpx;
  background: #3c8bff;
  opacity: 0.72;
}

.hero-content {
  position: relative;
  z-index: 1;
  min-height: 204rpx;
  padding: 52rpx 28rpx 40rpx 32rpx;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.hero-copy {
  min-width: 0;
}

.hero-title {
  font-size: 36rpx;
  font-weight: 800;
  line-height: 44rpx;
}

.hero-subtitle {
  margin-top: 8rpx;
  color: #ddebff;
  font-size: 26rpx;
  line-height: 32rpx;
}

.hero-actions {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding-top: 10rpx;
}

.reset-button {
  width: 144rpx;
  height: 60rpx;
  border: 2rpx solid #bbd7ff;
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 60rpx;
  text-align: center;
}

.cart-shortcut {
  position: relative;
  width: 68rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cart-icon {
  width: 48rpx;
  height: 48rpx;
}

.cart-badge {
  position: absolute;
  right: -2rpx;
  top: -8rpx;
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 8rpx;
  border: 4rpx solid #ffffff;
  border-radius: 999rpx;
  background: #e34d59;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 800;
  line-height: 28rpx;
  text-align: center;
}

.button-hover {
  opacity: 0.82;
}

.order-content {
  position: relative;
  margin-top: -56rpx;
  padding: 0 24rpx 48rpx;
}

.switch-tip {
  width: 232rpx;
  height: 40rpx;
  margin: 0 auto 16rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.88);
  color: #98a2b3;
  font-size: 22rpx;
  line-height: 40rpx;
  text-align: center;
}
