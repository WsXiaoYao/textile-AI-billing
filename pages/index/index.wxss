.order-page {
  min-height: 100vh;
  padding-bottom: calc(252rpx + env(safe-area-inset-bottom));
  background: #f5f8fc;
  color: #172033;
}

.order-hero {
  position: relative;
  height: 148rpx;
  overflow: hidden;
  background: #2f7df6;
  color: #ffffff;
}

.hero-accent {
  display: none;
}

.hero-content {
  position: relative;
  z-index: 1;
  min-height: 148rpx;
  padding: 0;
}

.hero-copy {
  position: absolute;
  left: 32rpx;
  top: 22rpx;
  width: 240rpx;
}

.hero-title {
  font-size: 36rpx;
  font-weight: 800;
  line-height: 44rpx;
  white-space: nowrap;
}

.hero-subtitle {
  margin-top: 8rpx;
  color: #ddebff;
  font-size: 26rpx;
  line-height: 32rpx;
}

.hero-actions {
  position: absolute;
  right: 18rpx;
  top: 32rpx;
  width: 244rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 8rpx;
}

.reset-button {
  width: 144rpx;
  min-width: 144rpx;
  height: 60rpx;
  border: 2rpx solid #bbd7ff;
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 60rpx;
  text-align: center;
}

.cart-shortcut {
  position: relative;
  width: 76rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cart-icon {
  width: 48rpx;
  height: 48rpx;
}

.cart-badge {
  position: absolute;
  right: 2rpx;
  top: -2rpx;
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 8rpx;
  border: 4rpx solid #ffffff;
  border-radius: 999rpx;
  background: #e34d59;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 800;
  line-height: 28rpx;
  text-align: center;
}

.button-hover {
  opacity: 0.82;
}

.order-content {
  position: relative;
  margin-top: -26rpx;
  padding: 0 24rpx 48rpx;
}

customer-summary-card,
customer-switcher,
chat-bubble,
recognized-order-card,
order-composer {
  display: block;
}

.recognition-state-card {
  margin: -18rpx 0 28rpx;
  padding: 22rpx 24rpx 20rpx;
  border: 1rpx solid #d8e5f6;
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 18rpx rgba(13, 31, 61, 0.06);
}

.recognition-state-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.recognition-state-title {
  min-width: 0;
  flex: 1 1 auto;
  color: #1d2129;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 42rpx;
}

.recognition-state-badge {
  flex: 0 0 auto;
  min-width: 128rpx;
  height: 46rpx;
  padding: 0 18rpx;
  border: 1rpx solid #ffd591;
  border-radius: 999rpx;
  background: #fff7e8;
  color: #d46b08;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 44rpx;
  text-align: center;
}

.recognition-state-success .recognition-state-badge {
  border-color: #b7ebd1;
  background: #e8fff3;
  color: #0e8a62;
}

.recognition-state-failed .recognition-state-badge {
  border-color: #ffccc7;
  background: #fff1f0;
  color: #d94a55;
}

.recognition-state-line {
  margin-top: 16rpx;
  display: flex;
  gap: 12rpx;
  color: #667085;
  font-size: 24rpx;
  line-height: 34rpx;
}

.recognition-state-label {
  flex: 0 0 auto;
  color: #98a2b3;
}

.recognition-state-waiting {
  color: #1d2129;
}

.recognition-state-hint {
  margin-top: 16rpx;
  color: #1d2129;
  font-size: 26rpx;
  line-height: 38rpx;
}

.recognition-state-foot {
  margin-top: 16rpx;
  padding: 12rpx 16rpx;
  border-radius: 10rpx;
  background: #f0f6ff;
  color: #2f7df6;
  font-size: 22rpx;
  line-height: 32rpx;
}

.switch-tip {
  width: 232rpx;
  height: 40rpx;
  margin: 0 auto 16rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.88);
  color: #98a2b3;
  font-size: 22rpx;
  line-height: 40rpx;
  text-align: center;
}

.flow-layer {
  position: fixed;
  inset: 0;
  z-index: 50;
  pointer-events: auto;
}

.flow-mask {
  position: absolute;
  inset: 0;
  background: rgba(15, 23, 42, 0.32);
  opacity: 0;
  transition: opacity 180ms ease;
}

.light-mask {
  background: rgba(15, 23, 42, 0.1);
}

.flow-layer-active .flow-mask {
  opacity: 1;
}

.flow-sheet {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  border: 1rpx solid #d8e5f6;
  border-bottom: 0;
  border-radius: 32rpx 32rpx 0 0;
  background: #ffffff;
  box-shadow: 0 -16rpx 48rpx rgba(20, 31, 51, 0.16);
  transform: translateY(100%);
  transition: transform 220ms ease;
  overflow: hidden;
}

.flow-layer-active .flow-sheet {
  transform: translateY(0);
}

.sheet-handle {
  width: 96rpx;
  height: 8rpx;
  margin: 18rpx auto 0;
  border-radius: 999rpx;
  background: #d8e5f6;
}

.sheet-title {
  color: #1d2129;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 46rpx;
}

.sheet-subtitle {
  margin-top: 2rpx;
  color: #667085;
  font-size: 24rpx;
  line-height: 34rpx;
}

.sheet-amount {
  color: #d94a55;
  font-size: 40rpx;
  font-weight: 900;
  line-height: 52rpx;
  text-align: right;
}

.sheet-summary {
  text-align: right;
}

.sheet-cancel {
  flex: 0 0 112rpx;
  height: 56rpx;
  color: #667085;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 56rpx;
  text-align: right;
}

.cart-sheet {
  height: calc(100vh - 104rpx);
  min-height: 820rpx;
}

.cart-sheet-head,
.customer-sheet-head,
.product-sheet-head {
  padding: 20rpx 30rpx 0;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.customer-sheet-head {
  position: relative;
  flex: 0 0 auto;
  align-items: center;
  padding-top: 18rpx;
  padding-right: 146rpx;
}

.customer-sheet-head .sheet-cancel {
  position: absolute;
  right: 30rpx;
  top: 18rpx;
}

.product-sheet-head {
  position: relative;
  flex: 0 0 auto;
  align-items: center;
  padding-top: 18rpx;
  padding-right: 146rpx;
}

.product-sheet-head .sheet-cancel {
  position: absolute;
  right: 30rpx;
  top: 18rpx;
}

.cart-notice {
  margin: 22rpx 30rpx 0;
  height: 96rpx;
