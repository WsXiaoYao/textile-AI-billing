.order-page {
  min-height: 100vh;
  padding-bottom: 120rpx;
  background: #f0f6fd;
}

.hero {
  min-height: 172rpx;
  padding: 24rpx 28rpx 38rpx;
  background: #1677ff;
  color: #ffffff;
}

.hero-main {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.hero-title {
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1.2;
}

.hero-subtitle {
  margin-top: 6rpx;
  font-size: 24rpx;
  line-height: 1.3;
  opacity: 0.9;
}

.hero-actions {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding-top: 2rpx;
}

.reset-btn {
  min-width: 132rpx;
  min-height: 54rpx;
  padding: 0 22rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.7);
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
}

.cart-entry {
  position: relative;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cart-icon {
  width: 42rpx;
  height: 42rpx;
}

.cart-badge {
  position: absolute;
  right: -10rpx;
  top: -12rpx;
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid #ffffff;
  border-radius: 999rpx;
  background: #e5484d;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 1;
}

.content {
  margin-top: -50rpx;
  padding: 0 24rpx 28rpx;
}

.customer-card {
  min-height: 146rpx;
  padding: 20rpx 24rpx;
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.customer-left {
  min-width: 0;
  flex: 1;
}

.card-label {
  color: #1677ff;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.2;
}

.customer-name-row {
  margin-top: 14rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-width: 0;
}

.customer-name {
  color: #172033;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.1;
  max-width: 238rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.customer-code {
  margin-top: 14rpx;
  color: #667085;
  font-size: 24rpx;
  line-height: 1.2;
}

.customer-money {
  width: 190rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  justify-content: center;
}

.money-label {
  color: #667085;
  font-size: 22rpx;
  line-height: 1.2;
}

.receivable {
  margin-top: 14rpx;
  color: #1677ff;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.2;
}

.customer-tabs {
  margin-top: 22rpx;
  display: flex;
  gap: 12rpx;
}

.customer-tab {
  min-width: 0;
  height: 56rpx;
  padding: 0 14rpx;
  flex: 1;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #b9d7ff;
  border-radius: 12rpx;
  background: #ffffff;
  color: #1677ff;
  font-size: 24rpx;
  font-weight: 800;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.customer-tab-wide {
  flex: 1.38;
}

.customer-tab-active {
  background: #1677ff;
  border-color: #1677ff;
  color: #ffffff;
}

.customer-tab-more {
  flex: 0.74;
}

.toast {
  width: 250rpx;
  height: 40rpx;
  margin: 4rpx auto 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.88);
  color: #98a2b3;
  font-size: 22rpx;
}

.message-bubble {
  margin: 0 32rpx 30rpx;
  padding: 22rpx 28rpx;
  border-radius: 16rpx;
  background: #2698d8;
  color: #ffffff;
  font-size: 28rpx;
  line-height: 1.5;
  box-shadow: 0 8rpx 18rpx rgba(38, 152, 216, 0.18);
}

.cart-card {
  padding: 24rpx 26rpx;
}

.cart-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 20rpx;
}

.cart-title {
  color: #172033;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.3;
}

.cart-link {
  color: #12b76a;
  font-size: 22rpx;
  font-weight: 700;
  white-space: nowrap;
}

.cart-table-head {
  margin-top: 22rpx;
  display: grid;
  grid-template-columns: 1fr 1.4fr 0.8fr 0.9fr;
  column-gap: 14rpx;
  color: #98a2b3;
  font-size: 22rpx;
}

.cart-row {
  min-height: 62rpx;
  display: grid;
  grid-template-columns: 1fr 1.4fr 0.8fr 0.9fr;
  column-gap: 14rpx;
  align-items: center;
  border-bottom: 1rpx solid #edf1f5;
  color: #172033;
  font-size: 26rpx;
}

.cart-row-last {
  border-bottom: 0;
}

.item-name,
.item-spec,
.item-quantity {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-spec {
  color: #667085;
}

.amount-head,
.item-amount {
  text-align: center;
}

.item-amount {
  color: #e5484d;
}

.cart-total {
  margin-top: 14rpx;
  color: #e5484d;
  font-size: 28rpx;
  text-align: right;
}

.composer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 10;
  padding: 14rpx 24rpx 14rpx;
  background: rgba(255, 255, 255, 0.96);
  border-top: 1rpx solid #e3e8ef;
}

.composer-inner {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.composer-input {
  height: 68rpx;
  min-width: 0;
  flex: 1;
  padding: 0 24rpx;
  border: 1rpx solid #e3e8ef;
  border-radius: 12rpx;
  background: #f8fafc;
  color: #172033;
  font-size: 26rpx;
}

.composer-placeholder {
  color: #98a2b3;
}

.recognize-btn {
  width: 98rpx;
  height: 68rpx;
  border-radius: 12rpx;
  background: #1677ff;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 800;
}
