.checkout-page {
  min-height: 100vh;
  background: #f4f7fb;
  color: #172033;
}

.checkout-scroll {
  height: 100vh;
}

.checkout-content {
  padding: 24rpx 24rpx 168rpx;
}

.checkout-card {
  margin-top: 20rpx;
  padding: 26rpx 28rpx;
  border: 1rpx solid #d8e5f6;
  border-radius: 22rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(13, 31, 61, 0.05);
}

.checkout-card:first-child {
  margin-top: 0;
}

.card-head {
  position: relative;
  min-height: 58rpx;
  padding-right: 130rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.card-title {
  color: #172033;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 44rpx;
}

.card-desc {
  margin-top: 8rpx;
  color: #667085;
  font-size: 24rpx;
  line-height: 34rpx;
}

.customer-tag {
  height: 48rpx;
  padding: 0 18rpx;
  border: 1rpx solid #d8e5f6;
  border-radius: 999rpx;
  background: #f2f7ff;
  color: #2e7bef;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 48rpx;
  white-space: nowrap;
}

.customer-debt {
  position: absolute;
  top: 0;
  right: 0;
  text-align: right;
}

.debt-label {
  color: #98a2b3;
  font-size: 22rpx;
  line-height: 30rpx;
}

.debt-value {
  color: #d94a55;
  font-size: 36rpx;
  font-weight: 900;
  line-height: 46rpx;
}

.info-row {
  min-height: 48rpx;
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.info-row:first-of-type {
  margin-top: 10rpx;
}

.info-row-address {
  min-height: 68rpx;
  align-items: flex-start;
}

.info-label {
  flex: 0 0 170rpx;
  color: #1d2129;
  font-size: 26rpx;
  line-height: 40rpx;
}

.info-value {
  min-width: 0;
  flex: 1;
  color: #1d2129;
  font-size: 26rpx;
  line-height: 40rpx;
}

.info-strong {
  font-weight: 900;
}

.info-muted {
  color: #667085;
}

.info-primary {
  color: #2e7bef;
  font-weight: 900;
}

.product-detail-card {
  padding: 26rpx 30rpx 18rpx;
}

.product-head {
  margin-top: 22rpx;
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  color: #98a2b3;
  font-size: 24rpx;
  line-height: 34rpx;
}

.product-row {
  min-height: 124rpx;
  padding: 22rpx 0 20rpx;
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
  border-bottom: 1rpx solid #d8e5f6;
}

.product-row:last-child {
  border-bottom: 0;
}

.product-col-main,
.product-main {
  min-width: 0;
  flex: 1;
}

.product-col-qty,
.product-qty {
  flex: 0 0 88rpx;
  text-align: center;
}

.product-col-price,
.product-price {
  flex: 0 0 68rpx;
  text-align: right;
}

.product-col-amount,
.product-amount {
  flex: 0 0 112rpx;
  text-align: right;
}

.product-name {
  color: #1d2129;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 40rpx;
}

.product-meta {
  margin-top: 4rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  color: #667085;
  font-size: 24rpx;
  line-height: 34rpx;
  white-space: nowrap;
}

.product-meta text:last-child {
  color: #1d2129;
}

.stock-danger,
.product-amount,
.amount-danger {
  color: #d94a55;
}

.product-meta .stock-danger {
  color: #d94a55;
}

.product-qty,
.amount-normal {
  color: #172033;
  font-weight: 900;
}

.product-qty,
.product-price,
.product-amount {
  margin-top: 12rpx;
  white-space: nowrap;
}

.product-qty {
  font-size: 28rpx;
  line-height: 40rpx;
}

.product-price {
  color: #667085;
  font-size: 26rpx;
  line-height: 38rpx;
}

.product-amount {
  font-size: 28rpx;
  font-weight: 900;
  line-height: 40rpx;
}

.amount-row {
  min-height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  color: #667085;
  font-size: 24rpx;
  line-height: 36rpx;
}

.amount-row:first-of-type {
  margin-top: 22rpx;
}

.amount-row > view:last-child {
  font-weight: 900;
}

.amount-primary {
  color: #2e7bef;
}

.amount-edit-value {
  min-width: 150rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  color: #2e7bef;
  font-weight: 900;
}

.amount-input-prefix {
  flex: 0 0 auto;
  font-size: 28rpx;
  line-height: 48rpx;
}

.discount-input {
  width: 112rpx;
  height: 48rpx;
  padding: 0;
  color: #2e7bef;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 48rpx;
  text-align: right;
}

.amount-success {
  color: #0e8a62;
}

.prepaid-panel {
  margin-top: 18rpx;
  padding: 20rpx 24rpx;
  border: 1rpx solid #d8e5f6;
  border-radius: 18rpx;
  background: #f2f7ff;
}

.prepaid-panel .amount-row:first-of-type {
  margin-top: 0;
}

.compact {
  min-height: 44rpx;
}

.prepaid-note {
  margin-top: 10rpx;
  color: #2e7bef;
  font-size: 20rpx;
  line-height: 30rpx;
}

.remark-textarea {
  width: 100%;
  height: 104rpx;
  margin-top: 20rpx;
  padding: 18rpx 22rpx;
  border: 1rpx solid #d8e5f6;
  border-radius: 18rpx;
  color: #172033;
  font-size: 24rpx;
  line-height: 34rpx;
}

.input-placeholder {
  color: #98a2b3;
}

.print-card {
  min-height: 240rpx;
  padding: 26rpx 28rpx 28rpx;
  display: block;
}

.print-card > view:first-child {
  width: 100%;
}

.print-card .card-title {
  white-space: nowrap;
}

.print-actions {
  margin-top: 20rpx;
  display: flex;
  justify-content: flex-end;
  gap: 24rpx;
}

.print-btn {
  height: 72rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 72rpx;
  text-align: center;
}

.print-btn.secondary {
  width: 144rpx;
  border: 1rpx solid #d8e5f6;
  color: #2e7bef;
  background: #ffffff;
}

.print-btn.primary {
  width: 206rpx;
  color: #ffffff;
  background: #2e7bef;
}

.checkout-bottom {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  min-height: 144rpx;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  gap: 16rpx;
  border-top: 1rpx solid #d8e5f6;
  background: #ffffff;
}

.bottom-amount {
  min-width: 0;
  flex: 1;
}

.bottom-label {
  color: #667085;
  font-size: 24rpx;
  line-height: 34rpx;
}

.bottom-value {
  color: #d94a55;
  font-size: 44rpx;
  font-weight: 900;
  line-height: 56rpx;
}

.bottom-btn {
  height: 84rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 84rpx;
  text-align: center;
}

.bottom-btn.secondary {
  flex: 0 0 196rpx;
  border: 1rpx solid #d8e5f6;
  color: #2e7bef;
  background: #ffffff;
}

.bottom-btn.primary {
  flex: 0 0 250rpx;
  color: #ffffff;
  background: #2e7bef;
}

.bottom-btn.disabled {
  opacity: 0.6;
}
