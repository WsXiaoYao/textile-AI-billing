<view class="supplier-page">
  <scroll-view class="supplier-scroll" scroll-y enhanced show-scrollbar="{{false}}" scroll-top="{{scrollTop}}" bindscroll="onListScroll">
    <view class="supplier-content">
      <view class="toolbar-card">
        <view class="search-row">
          <input
            class="search-input"
            value="{{keyword}}"
            placeholder="搜索供应商名称、电话"
            placeholder-class="search-placeholder"
            confirm-type="search"
            bindinput="onKeywordInput"
            bindconfirm="onKeywordConfirm"
          />
        </view>

        <view class="status-tabs">
          <block wx:for="{{statusTabs}}" wx:key="value">
            <view
              class="status-tab {{activeStatus == item.value ? 'status-tab-active' : ''}}"
              data-value="{{item.value}}"
              bindtap="onStatusTap"
            >
              {{item.label}}
            </view>
          </block>
        </view>
      </view>

      <view class="supplier-list" wx:if="{{displayedSuppliers.length}}">
        <block wx:for="{{displayedSuppliers}}" wx:key="id">
          <view class="supplier-card" data-id="{{item.id}}" bindtap="onOpenSupplier">
            <view class="supplier-main">
              <view class="supplier-title-row">
                <view class="supplier-name">{{item.name}}</view>
                <view wx:if="{{item.isCommon}}" class="supplier-chip chip-primary">常用</view>
                <view wx:if="{{item.statusKey == 'disabled'}}" class="supplier-chip chip-muted">停用</view>
              </view>
              <view class="supplier-meta">电话 {{item.phone || '未填写'}} · {{item.address || '未填写地址'}}</view>
              <view class="supplier-desc">{{item.latestText}}</view>
            </view>
            <view class="supplier-side">
              <view class="side-label">合同金额</view>
              <view class="side-amount">{{item.totalPurchaseText}}</view>
            </view>
          </view>
        </block>
      </view>

      <view class="empty-state" wx:else>
        <view class="empty-title">没有匹配的供应商</view>
        <view class="empty-desc">换个名称、电话或筛选条件再试试。</view>
      </view>
    </view>
  </scroll-view>

  <view class="bottom-actions">
    <view class="bottom-btn bottom-btn-secondary" bindtap="onBackTap">返回</view>
    <view class="bottom-btn bottom-btn-primary" bindtap="onAddSupplierTap">新增供应商</view>
  </view>
  <back-to-top show="{{showBackTop}}" bottom="220rpx" bind:backtop="onBackTopTap" />
</view>
