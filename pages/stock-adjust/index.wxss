.adjust-page {
  min-height: 100vh;
  background: #f4f7fb;
  color: #172033;
}

.adjust-scroll {
  height: 100vh;
}

.adjust-content {
  padding: 24rpx 24rpx 148rpx;
}

.adjust-card {
  margin-top: 20rpx;
  padding: 26rpx 28rpx;
  border: 1rpx solid #d8e5f6;
  border-radius: 22rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(13, 31, 61, 0.05);
}

.adjust-card:first-child {
  margin-top: 0;
}

.card-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.card-title {
  color: #172033;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 44rpx;
}

.card-desc {
  margin-top: 8rpx;
  color: #667085;
  font-size: 23rpx;
  line-height: 34rpx;
}

.form-list {
  margin-top: 18rpx;
}

.form-row {
  min-height: 88rpx;
  display: flex;
  align-items: center;
  border-top: 1rpx solid #d8e5f6;
}

.form-row:first-child {
  border-top: 0;
}

.form-label {
  flex: 0 0 170rpx;
  color: #172033;
  font-size: 27rpx;
  font-weight: 800;
  line-height: 40rpx;
}

.form-value,
.form-input {
  min-width: 0;
  flex: 1;
  height: 72rpx;
  color: #172033;
  font-size: 27rpx;
  font-weight: 800;
  line-height: 72rpx;
}

.amount-input {
  color: #2e7bef;
}

.adjust-control {
  min-width: 0;
  flex: 1;
  height: 72rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.adjust-control .amount-input {
  height: 70rpx;
  line-height: 70rpx;
}

.direction-group {
  flex: 0 0 196rpx;
  height: 62rpx;
  padding: 5rpx;
  display: flex;
  align-items: center;
  border: 1rpx solid #d8e5f6;
  border-radius: 999rpx;
  background: #f8fafc;
  box-sizing: border-box;
}

.direction-btn {
  min-width: 0;
  flex: 1;
  height: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  color: #667085;
  font-size: 23rpx;
  font-weight: 900;
  line-height: 1;
}

.direction-increase.direction-active {
  background: #eafaf3;
  color: #0e8a62;
  box-shadow: 0 4rpx 12rpx rgba(14, 138, 98, 0.12);
}

.direction-decrease.direction-active {
  background: #fff0f2;
  color: #d94a55;
  box-shadow: 0 4rpx 12rpx rgba(217, 74, 85, 0.12);
}

.form-value-success {
  color: #0e8a62;
}

.form-value-warning {
  color: #d77a00;
}

.form-value-danger {
  color: #d94a55;
}

.input-placeholder {
  color: #98a2b3;
  font-weight: 400;
}

.note-input {
  width: 100%;
  height: 128rpx;
  margin-top: 20rpx;
  padding: 22rpx;
  box-sizing: border-box;
  border: 1rpx solid #d8e5f6;
  border-radius: 18rpx;
  background: #ffffff;
  color: #172033;
  font-size: 26rpx;
  line-height: 38rpx;
}

.record-count {
  flex: 0 0 auto;
  color: #667085;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 36rpx;
}

.record-list {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.record-item {
  padding: 20rpx;
  border: 1rpx solid #d8e5f6;
  border-radius: 18rpx;
  background: #fbfdff;
}

.record-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.record-operator {
  color: #172033;
  font-size: 27rpx;
  font-weight: 900;
  line-height: 38rpx;
}

.record-time {
  color: #667085;
  font-size: 22rpx;
  line-height: 32rpx;
}

.record-metrics {
  margin-top: 14rpx;
  display: flex;
}

.record-metric {
  min-width: 0;
  flex: 1;
}

.record-label {
  color: #98a2b3;
  font-size: 22rpx;
  line-height: 30rpx;
}

.record-value {
  margin-top: 4rpx;
  color: #172033;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 36rpx;
}

.record-primary {
  color: #2e7bef;
}

.record-note {
  margin-top: 14rpx;
  padding: 12rpx 16rpx;
  border-radius: 12rpx;
  background: #eaf3ff;
  color: #2e7bef;
  font-size: 22rpx;
  line-height: 32rpx;
}

.empty-record {
  margin-top: 20rpx;
  padding: 22rpx;
  border: 1rpx dashed #d8e5f6;
  border-radius: 18rpx;
  background: #fbfdff;
  color: #667085;
  font-size: 24rpx;
  line-height: 36rpx;
  text-align: center;
}

.bottom-actions {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 20;
  min-height: 108rpx;
  padding: 14rpx 24rpx calc(14rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  gap: 18rpx;
  border-top: 1rpx solid #e6ecf5;
  background: #ffffff;
}

.bottom-btn {
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 14rpx;
  font-size: 28rpx;
  font-weight: 900;
}

.bottom-btn-secondary {
  flex: 0 0 184rpx;
  border: 1rpx solid #d8e5f6;
  background: #ffffff;
  color: #2e7bef;
}

.bottom-btn-primary {
  flex: 1;
  background: #2e7bef;
  color: #ffffff;
}
