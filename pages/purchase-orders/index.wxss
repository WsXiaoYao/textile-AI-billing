.purchase-page {
  min-height: 100vh;
  background: #f4f7fb;
  color: #172033;
}

.purchase-scroll {
  height: 100vh;
}

.purchase-content {
  padding: 24rpx 24rpx 148rpx;
}

.order-card {
  border: 1rpx solid #d8e5f6;
  border-radius: 22rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(13, 31, 61, 0.05);
}

.order-list {
  margin-top: 22rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.order-card {
  min-height: 150rpx;
  padding: 22rpx;
  display: flex;
  gap: 14rpx;
}

.order-main {
  min-width: 0;
  flex: 1;
}

.order-title-row {
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.supplier-name {
  min-width: 0;
  flex: 1;
  color: #172033;
  font-size: 29rpx;
  font-weight: 900;
  line-height: 40rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.order-meta,
.order-warehouse {
  margin-top: 8rpx;
  color: #667085;
  font-size: 23rpx;
  line-height: 32rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.order-side {
  flex: 0 0 176rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  justify-content: center;
}

.order-amount {
  max-width: 176rpx;
  color: #d94a55;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 36rpx;
  text-align: right;
  white-space: nowrap;
}

.empty-state {
  margin-top: 32rpx;
  padding: 52rpx 24rpx;
  border: 1rpx dashed #d8e5f6;
  border-radius: 22rpx;
  background: #ffffff;
  text-align: center;
}

.empty-title {
  color: #172033;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 42rpx;
}

.empty-desc {
  margin-top: 8rpx;
  color: #667085;
  font-size: 24rpx;
  line-height: 36rpx;
}

.filter-layer {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 80;
}

.filter-backdrop {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  opacity: 0;
  background: rgba(23, 32, 51, 0.46);
  transition: opacity 240ms ease-out;
}

.filter-layer-active .filter-backdrop {
  opacity: 1;
}

.filter-drawer {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  width: 600rpx;
  max-width: 82vw;
  display: flex;
  flex-direction: column;
  background: #f6f7f9;
  border-top-left-radius: 28rpx;
  border-bottom-left-radius: 28rpx;
  box-shadow: -16rpx 0 48rpx rgba(23, 32, 51, 0.18);
  overflow: hidden;
  transform: translateX(100%);
  transition: transform 240ms cubic-bezier(0.2, 0.8, 0.2, 1);
  will-change: transform;
}

.filter-layer-active .filter-drawer {
  transform: translateX(0);
}

.filter-header {
  flex: 0 0 108rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 28rpx;
  background: #ffffff;
  border-bottom: 1rpx solid #edf1f5;
}

.filter-title {
  color: #172033;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 44rpx;
}

.filter-selected {
  color: #667085;
  font-size: 24rpx;
  line-height: 36rpx;
}

.filter-body {
  min-height: 0;
  flex: 1;
  box-sizing: border-box;
  padding: 24rpx 24rpx 144rpx;
}

.filter-section {
  margin-top: 20rpx;
  padding: 24rpx;
  border-radius: 20rpx;
  background: #ffffff;
}

.filter-section:first-child {
  margin-top: 0;
}

.filter-section-title {
  color: #172033;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 40rpx;
}

.filter-chip-grid {
  margin-top: 20rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx 14rpx;
}

.filter-chip {
  box-sizing: border-box;
  min-width: 160rpx;
  max-width: 100%;
  height: 64rpx;
  padding: 0 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid transparent;
  border-radius: 16rpx;
  background: #f4f7fb;
  color: #1d2129;
  font-size: 25rpx;
  line-height: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.filter-chip-active {
  border-color: #2e7bef;
  background: #eaf3ff;
  color: #2e7bef;
  font-weight: 800;
}

.filter-chip-disabled {
  color: #98a2b3;
}

.filter-footer {
  position: absolute;
  right: 0;
  bottom: 0;
  left: 0;
  box-sizing: border-box;
  height: 120rpx;
  display: flex;
  gap: 20rpx;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #edf1f5;
  background: #ffffff;
}

.filter-reset,
.filter-done {
  box-sizing: border-box;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1;
}

.filter-reset {
  flex: 0 0 196rpx;
  border: 1rpx solid #b9d7ff;
  background: #ffffff;
  color: #2e7bef;
}

.filter-done {
  flex: 1;
  background: #2e7bef;
  color: #ffffff;
}

.bottom-actions {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 20;
  min-height: 108rpx;
  padding: 14rpx 24rpx calc(14rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  gap: 18rpx;
  border-top: 1rpx solid #e6ecf5;
  background: #ffffff;
}

.bottom-btn {
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 14rpx;
  font-size: 28rpx;
  font-weight: 900;
}

.bottom-btn-secondary {
  flex: 0 0 184rpx;
  border: 1rpx solid #d8e5f6;
  background: #ffffff;
  color: #2e7bef;
}

.bottom-btn-primary {
  flex: 1;
  background: #2e7bef;
  color: #ffffff;
}
